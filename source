						})
						AddCorner(item, 3)
						local chk = Make("Frame", {
							Size             = UDim2.fromOffset(12, 12),
							Position         = UDim2.fromOffset(4, 4),
							BackgroundColor3 = isOn and Theme.Accent or Theme.Toggle_Off,
							ZIndex           = 23,
							Parent           = item,
						})
						AddCorner(chk, 2)
						AddStroke(chk, isOn and Theme.AccentLight or Theme.SectionBorder, 1)
						if isOn then
							Make("TextLabel", {
								Size                   = UDim2.fromScale(1, 1),
								BackgroundTransparency = 1,
								Text                   = "✓",
								TextColor3             = Color3.fromRGB(255, 255, 255),
								Font                   = Enum.Font.GothamBold,
								TextSize               = 9,
								ZIndex                 = 24,
								Parent                 = chk,
							})
						end
						Make("TextLabel", {
