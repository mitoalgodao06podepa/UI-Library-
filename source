	local function activateTab(tabObj)
		if WindowObj._activeTab then
			WindowObj._activeTab._container.Visible = false
			local ob = tabButtons[WindowObj._activeTab]
			if ob then
				Tween(ob, { BackgroundColor3 = Theme.TabBG }, 0.12)
				ob:FindFirstChild("Label").TextColor3 = Theme.TabText
				local ind = ob:FindFirstChild("Indicator")
				if ind then Tween(ind, { BackgroundTransparency = 1 }, 0.12) end
			end
		end
		WindowObj._activeTab = tabObj
		tabObj._container.Visible = true
		local ob = tabButtons[tabObj]
		if ob then
			Tween(ob, { BackgroundColor3 = Theme.TabActive }, 0.12)
			ob:FindFirstChild("Label").TextColor3 = Theme.TabActiveText
			local ind = ob:FindFirstChild("Indicator")
			if ind then Tween(ind, { BackgroundTransparency = 0 }, 0.12) end
		end
	end

