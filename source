local function v2(x, y) return Vector2.new(x, y) end
local function v3(r, g, b) return Vector3.new(r, g, b) end
local function clamp(v, a, b) return math.max(a, math.min(b, v)) end
local function hit(mx, my, x, y, w, h) return mx >= x and mx <= x+w and my >= y and my <= y+h end

local function D(cls, props)
    local o = Drawing.new(cls)
    for k, v in pairs(props) do o[k] = v end
    _pool[#_pool+1] = o
    return o
end

local function Sq(p)  return D("Square", p) end
local function Tx(p)  return D("Text",   p) end
local function Ci(p)  return D("Circle", p) end

local mouse = { x=0, y=0, down=false, click=false, _prev=false }

local function updateMouse()
    local p = UIS:GetMouseLocation()
    mouse.x, mouse.y = p.X, p.Y
    mouse._prev = mouse.down
    mouse.down  = isleftpressed()
    mouse.click = mouse.down and not mouse._prev
end

local EH = {
    toggle=22, button=26, slider=36,
    dropdown=42, multidropdown=42,
    keybind=24, textinput=42,
    colorpicker=26, label=18, separator=10,
}

local function secH(sec)
    local h = 26
    for _, el in ipairs(sec.elements) do
        h = h + (EH[el.type] or 22)
        if el.type == "colorpicker" and el.open then h = h + 72 end
    end
    return h + 8
end

local function pushNotif(cfg)
    local nW, nH = 230, 52
    local col = cfg.color or Theme.accent
    local n = {
        born = tick(),
        dur  = cfg.duration or 3,
        alive = true,
        _bg   = Sq{Visible=false, Filled=true,  Color=Theme.notif_bg,  Opacity=0.97, Rounding=5, Position=v2(0,0), Size=v2(nW,nH),    ZIndex=990},
        _brd  = Sq{Visible=false, Filled=false, Color=Theme.section_brd, Opacity=0.5, Thickness=1, Rounding=5, Position=v2(0,0), Size=v2(nW,nH), ZIndex=991},
        _bar  = Sq{Visible=false, Filled=true,  Color=col,             Opacity=1,    Rounding=2, Position=v2(0,0), Size=v2(3,nH-8),   ZIndex=992},
        _prog = Sq{Visible=false, Filled=true,  Color=col,             Opacity=0.3,  Rounding=0, Position=v2(0,0), Size=v2(nW,2),     ZIndex=992},
        _ttl  = Tx{Visible=false, Color=col,    Opacity=1,  Size=13, Center=false, Outline=true,  OutlineColor=v3(0,0,0), Position=v2(0,0), Text=cfg.title or "Notice",  ZIndex=993},
        _msg  = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=cfg.text  or "",        ZIndex=993},
    }
    _notifs[#_notifs+1] = n
end

local function renderNotifs()
    local vp = workspace.CurrentCamera.ViewportSize
    local bx = vp.X - 252
    local by = vp.Y - 72
    local alive = {}
    for _, n in ipairs(_notifs) do
        local e = tick() - n.born
        local nW, nH = 230, 52
        local slide = clamp(e / 0.22, 0, 1)
        local fade  = clamp((n.dur - e) / 0.35, 0, 1)
        local ox    = (1 - slide) * (nW + 30)
        local x, y  = bx + ox, by
        local vis   = e < n.dur + 0.38
        if not vis then n.alive = false end
        n._bg.Position,   n._bg.Size,   n._bg.Opacity,   n._bg.Visible   = v2(x,y), v2(nW,nH),    0.97*fade, vis
        n._brd.Position,  n._brd.Size,  n._brd.Opacity,  n._brd.Visible  = v2(x,y), v2(nW,nH),    0.5*fade,  vis
        n._bar.Position,  n._bar.Size,  n._bar.Opacity,  n._bar.Visible  = v2(x+6,y+4), v2(3,nH-8), fade,    vis
        n._prog.Position, n._prog.Size, n._prog.Opacity, n._prog.Visible = v2(x,y+nH-2), v2(nW*clamp(1-e/n.dur,0,1),2), 0.3*fade, vis
        n._ttl.Position,  n._ttl.Opacity,  n._ttl.Visible  = v2(x+14,y+8),  fade,       vis
        n._msg.Position,  n._msg.Opacity,  n._msg.Visible  = v2(x+14,y+27), 0.85*fade,  vis
        if n.alive then alive[#alive+1] = n end
    end
    _notifs = alive
end

UIS.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.UserInputType == Enum.UserInputType.Keyboard then
        if _listeningKB then
            local kn = inp.KeyCode == Enum.KeyCode.Escape and "Unbound" or inp.KeyCode.Name
            _listeningKB.value = kn
            _listeningKB._val.Text = kn
            _listeningKB.listening = false
            pcall(_listeningKB.cb, kn)
            _listeningKB = nil
            return
        end
        if _listeningTI then
            local kc = inp.KeyCode
            if kc == Enum.KeyCode.Return or kc == Enum.KeyCode.Escape then
                _listeningTI.focused = false
                pcall(_listeningTI.cb, _listeningTI.value)
                _listeningTI = nil
            elseif kc == Enum.KeyCode.Backspace then
                if #_listeningTI.value > 0 then
                    _listeningTI.value = _listeningTI.value:sub(1, -2)
                end
            else
                local n = kc.Name
                if #n == 1 then
                    local sh = UIS:IsKeyDown(Enum.KeyCode.LeftShift) or UIS:IsKeyDown(Enum.KeyCode.RightShift)
                    _listeningTI.value = _listeningTI.value .. (sh and n:upper() or n:lower())
                end
            end
        end
    end
end)

