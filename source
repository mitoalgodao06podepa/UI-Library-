		Parent = out, Position = dim2(0,2,0,2),
		Size = dim2(0,1,1,-4), BorderSizePixel = 0,
		BackgroundColor3 = themes.preset.accent
	}); library:apply_theme(acc, "accent", "BackgroundColor3")
	library:create("UIGradient", {
		Parent = acc, Rotation = 90,
		Color = rgbseq{rgbkey(0, rgb(255,255,255)), rgbkey(1, rgb(167,167,167))}
	})
	local acc_bot = library:create("Frame", {
		Parent = out, Position = dim2(0,2,1,-3),
		Size = dim2(0,-4,0,1), BorderSizePixel = 0,
		BackgroundColor3 = themes.preset.accent
	}); library:apply_theme(acc_bot, "accent", "BackgroundColor3")
	local idx = #library.notifications + 1
	library.notifications[idx] = out
	library:refresh_notifications()
	tween_service:Create(out, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
		{AnchorPoint = vec2(0,0)}):Play()
	tween_service:Create(acc_bot, TweenInfo.new(cfg.time, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
		{Size = dim2(1,-4,0,1)}):Play()
	task.spawn(function()
		task.wait(cfg.time)
		library.notifications[idx] = nil
		tween_service:Create(out, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
			{AnchorPoint = vec2(1,0), BackgroundTransparency = 1}):Play()
		for _, d in next, out:GetDescendants() do
			if d:IsA("TextLabel") then
				tween_service:Create(d, TweenInfo.new(1), {TextTransparency = 1}):Play()
			elseif d:IsA("Frame") then
				tween_service:Create(d, TweenInfo.new(1), {BackgroundTransparency = 1}):Play()
			elseif d:IsA("UIStroke") then
				tween_service:Create(d, TweenInfo.new(1), {Transparency = 1}):Play()
			end
		end
		task.wait(1)
		out:Destroy()
	end)
end

