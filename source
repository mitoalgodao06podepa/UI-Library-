	function cfg.render_option(text)
		local btn = library:create("TextButton", {
			Parent = sf, Text = tostring(text), FontFace = library.font,
			BackgroundTransparency = 1, Size = dim2(1,0,0,0),
			BorderSizePixel = 0, AutomaticSize = Enum.AutomaticSize.Y,
			TextSize = 12, BackgroundColor3 = rgb(255,255,255)
		}); library:apply_theme(btn, "accent", "TextColor3")
		library:create("UIStroke", {Parent = btn})
		return btn
	end

	function cfg.set_element_visible(b) lh.Visible = b end

	function cfg.refresh_options(list)
		if type(list) == "function" then return end
		for _, v in next, cfg.option_instances do v:Destroy() end
		cfg.option_instances = {}
		for _, opt in next, list do
			local btn = cfg.render_option(opt)
			insert(cfg.option_instances, btn)
			btn.MouseButton1Click:Connect(function()
				if cfg.current_instance and cfg.current_instance ~= btn then
					cfg.current_instance.TextColor3 = themes.preset.text
				end
				cfg.current_instance = btn
				btn.TextColor3 = themes.preset.accent
				flags[cfg.flag] = btn.Text
				cfg.callback(btn.Text)
			end)
		end
	end

	function cfg.set(val)
		for _, btn in next, cfg.option_instances do
			btn.TextColor3 = btn.Text == val and themes.preset.accent or themes.preset.text
		end
		flags[cfg.flag] = val
		cfg.callback(val)
	end

	cfg.refresh_options(cfg.items)
	cfg.set_element_visible(cfg.visible)
	library.visible_flags[cfg.flag] = cfg.set_element_visible
	library.config_flags[cfg.flag] = cfg.set

	return setmetatable(cfg, library)
end

