			function sectionObj:AddMultiDropdown(label, options, defaults, callback)
				callback = callback or function() end
				local selected = {}
				for _, d in ipairs(defaults or {}) do selected[d] = true end
				local opened = false

				local function getSelectedText()
					local keys = {}
					for k, v in pairs(selected) do if v then table.insert(keys, k) end end
					if #keys == 0 then return "None" end
					if #keys > 2  then return keys[1] .. " (+" .. (#keys - 1) .. ")" end
					return table.concat(keys, ", ")
				end

