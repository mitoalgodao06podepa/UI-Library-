-- ════════════════════════════════════════════════════════════
local notifOffset = 0
local notifActive = 0

local function ShowNotif(cfg2)
	cfg2 = cfg2 or {}
	local nTitle = cfg2.Title or "Notificação"
	local nText  = cfg2.Text  or ""
	local nTime  = cfg2.Time  or 3
	local nColor = cfg2.Color or Theme.Accent
	notifActive += 1
	local idx    = notifActive

	local yOff = -70 - ((idx - 1) * 60)

	local notif = Make("Frame", {
		Size             = UDim2.fromOffset(230, 52),
		Position         = UDim2.new(1, 250, 1, yOff),
		BackgroundColor3 = Theme.Notification,
		ZIndex           = 100,
		Parent           = RootGui,
	})
	Corner(notif, 6)
	Stroke(notif, nColor, 1)

	-- barra lateral colorida
	local bar = Make("Frame", {
		Size             = UDim2.fromOffset(3, 36),
		Position         = UDim2.fromOffset(0, 8),
		BackgroundColor3 = nColor,
		ZIndex           = 101,
		Parent           = notif,
	})
	Corner(bar, 99)

	Make("TextLabel", {
		Size                   = UDim2.new(1, -16, 0, 18),
		Position               = UDim2.fromOffset(10, 6),
		BackgroundTransparency = 1,
		Text                   = nTitle,
		TextColor3             = nColor,
		Font                   = Enum.Font.GothamBold,
		TextSize               = 11,
		TextXAlignment         = Enum.TextXAlignment.Left,
		ZIndex                 = 101,
		Parent                 = notif,
	})
	Make("TextLabel", {
		Size                   = UDim2.new(1, -16, 0, 22),
		Position               = UDim2.fromOffset(10, 24),
		BackgroundTransparency = 1,
		Text                   = nText,
		TextColor3             = Theme.SubText,
		Font                   = Enum.Font.Gotham,
		TextSize               = 10,
		TextXAlignment         = Enum.TextXAlignment.Left,
		TextWrapped            = true,
		ZIndex                 = 101,
		Parent                 = notif,
	})

	-- barra de progresso de tempo
	local progressBG = Make("Frame", {
		Size             = UDim2.new(1, -12, 0, 2),
		Position         = UDim2.new(0, 6, 1, -5),
		BackgroundColor3 = Theme.SectionBorder,
		ZIndex           = 101,
		Parent           = notif,
	})
	Corner(progressBG, 99)
	local progressFill = Make("Frame", {
		Size             = UDim2.new(1, 0, 1, 0),
		BackgroundColor3 = nColor,
		ZIndex           = 102,
		Parent           = progressBG,
	})
	Corner(progressFill, 99)

	-- slide in
	Tween(notif, { Position = UDim2.new(1, -244, 1, yOff) }, 0.3, Enum.EasingStyle.Back)
	-- progress
	Tween(progressFill, { Size = UDim2.new(0, 0, 1, 0) }, nTime, Enum.EasingStyle.Linear)

	task.delay(nTime, function()
		Tween(notif, { Position = UDim2.new(1, 250, 1, yOff), BackgroundTransparency = 1 }, 0.25)
		task.delay(0.3, function()
			notifActive = math.max(0, notifActive - 1)
			notif:Destroy()
		end)
	end)
end

