    self.x         = cfg.x     or 100
    self.y         = cfg.y     or 100
    self.width     = cfg.width  or 620
    self.height    = cfg.height or 430
    self.visible   = true
    self.minimised = false
    self.tabs      = {}
    self.activeTab = nil
    self._drag     = false
    self._dox      = 0
    self._doy      = 0

    local W, H = self.width, self.height
    local z = _zc; _zc = _zc + 200

    self._shad   = Sq{Visible=false, Filled=true,  Color=Theme.shadow,     Opacity=0.6,  Rounding=6, Position=v2(0,0), Size=v2(W+8,H+8), ZIndex=z}
