    self._tbar_r = Sq{Visible=false, Filled=true,  Color=Theme.titlebar,   Opacity=1,    Rounding=5, Position=v2(0,0), Size=v2(W,20),    ZIndex=z+3}
    self._tbar   = Sq{Visible=false, Filled=true,  Color=Theme.titlebar,   Opacity=1,    Rounding=0, Position=v2(0,0), Size=v2(W,30),    ZIndex=z+3}
    self._tdot   = Ci{Visible=false, Filled=true,  Color=Theme.accent,     Opacity=1,    Radius=4,   Position=v2(0,0),                   ZIndex=z+5}
    self._ttxt   = Tx{Visible=false, Color=Theme.accent, Opacity=1, Size=14, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=self.title, ZIndex=z+5}
    self._tacc   = Sq{Visible=false, Filled=true,  Color=Theme.accent,     Opacity=0.65, Position=v2(0,0), Size=v2(W,1), ZIndex=z+6}
    self._tbbar  = Sq{Visible=false, Filled=true,  Color=Theme.tabbar,     Opacity=1,    Position=v2(0,0), Size=v2(W,30), ZIndex=z+3}
    self._tbacc  = Sq{Visible=false, Filled=true,  Color=Theme.section_brd, Opacity=0.45, Position=v2(0,0), Size=v2(W,1), ZIndex=z+4}

    self._cbtn = {
        _bg  = Sq{Visible=false, Filled=true, Color=Theme.close,    Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(14,14), ZIndex=z+7},
        _txt = Tx{Visible=false, Color=Color3.fromRGB(255,255,255), Opacity=1, Size=12, Center=true, Outline=false, Position=v2(0,0), Text="×", ZIndex=z+8},
    }
    self._mbtn = {
        _bg  = Sq{Visible=false, Filled=true, Color=Theme.minimize, Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(14,14), ZIndex=z+7},
        _txt = Tx{Visible=false, Color=Color3.fromRGB(255,255,255), Opacity=1, Size=12, Center=true, Outline=false, Position=v2(0,0), Text="−", ZIndex=z+8},
    }

    _windows[#_windows+1] = self

    function self:Tab(name)
        local tab = { name=name, win=self, sections={}, idx=#self.tabs+1 }
        local tz = z + 10 + tab.idx*4
        tab._bg   = Sq{Visible=false, Filled=true, Color=Theme.tabbar, Opacity=0, Rounding=0, Position=v2(0,0), Size=v2(0,30), ZIndex=tz}
        tab._txt  = Tx{Visible=false, Color=Theme.tab_text, Opacity=1, Size=12, Center=true, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=name, ZIndex=tz+1}
        tab._line = Sq{Visible=false, Filled=true, Color=Theme.accent, Opacity=0, Position=v2(0,0), Size=v2(0,2), ZIndex=tz+2}
        self.tabs[#self.tabs+1] = tab
        if not self.activeTab then self.activeTab = tab end

        function tab:Section(cfg2)
            cfg2 = cfg2 or {}
            local sec = { name=cfg2.name or "", side=cfg2.side or "left", tab=tab, elements={} }
            local sz = tz + 20 + #tab.sections*8
            sec._bg  = Sq{Visible=false, Filled=true,  Color=Theme.section_bg,  Opacity=0.96, Rounding=4, Position=v2(0,0), Size=v2(0,0), ZIndex=sz}
            sec._brd = Sq{Visible=false, Filled=false, Color=Theme.section_brd, Opacity=0.45, Thickness=1, Rounding=4, Position=v2(0,0), Size=v2(0,0), ZIndex=sz+1}
            sec._ttl = Tx{Visible=false, Color=Theme.section_title, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=sec.name, ZIndex=sz+2}
            sec._sep = Sq{Visible=false, Filled=true, Color=Theme.accent_dark, Opacity=0.35, Position=v2(0,0), Size=v2(0,1), ZIndex=sz+2}
            tab.sections[#tab.sections+1] = sec

            local function nz() return sz + 3 + #sec.elements*6 end

            function sec:Toggle(c)
                local el = { type="toggle", name=c.name or "", value=c.default~=nil and c.default or false, cb=c.callback or function()end }
                local ez = nz()
                el._box  = Sq{Visible=false, Filled=true, Color=Theme.tgl_off, Opacity=1, Rounding=8, Position=v2(0,0), Size=v2(32,16), ZIndex=ez}
                el._knob = Ci{Visible=false, Filled=true, Color=Color3.fromRGB(228,232,242), Opacity=1, Radius=6, Position=v2(0,0), ZIndex=ez+1}
                el._txt  = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name, ZIndex=ez+1}
                sec.elements[#sec.elements+1] = el
                function el:Set(v) el.value = v end
                function el:Get() return el.value end
                return el
            end

            function sec:Button(c)
                local el = { type="button", name=c.name or "", cb=c.callback or function()end }
                local ez = nz()
                el._bg  = Sq{Visible=false, Filled=true,  Color=Theme.btn_bg,      Opacity=1, Rounding=4, Position=v2(0,0), Size=v2(0,22), ZIndex=ez}
                el._brd = Sq{Visible=false, Filled=false, Color=Theme.section_brd, Opacity=0.4, Thickness=1, Rounding=4, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+1}
                el._txt = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=true, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name, ZIndex=ez+2}
                sec.elements[#sec.elements+1] = el
                function el:SetLabel(s) el.name = s; el._txt.Text = s end
                return el
            end

            function sec:Slider(c)
                local el = { type="slider", name=c.name or "", min=c.min or 0, max=c.max or 100, value=c.default or 0, dec=c.decimals or 0, cb=c.callback or function()end, _sl=false }
                local ez = nz()
                el._txt  = Tx{Visible=false, Color=Theme.text,   Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name, ZIndex=ez+1}
                el._val  = Tx{Visible=false, Color=Theme.accent, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text="0",     ZIndex=ez+1}
                el._bg   = Sq{Visible=false, Filled=true, Color=Theme.slider_bg,   Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(0,5), ZIndex=ez}
                el._fill = Sq{Visible=false, Filled=true, Color=Theme.slider_fill, Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(0,5), ZIndex=ez+1}
                el._knob = Ci{Visible=false, Filled=true, Color=Color3.fromRGB(210,230,228), Opacity=1, Radius=5, Position=v2(0,0), ZIndex=ez+2}
                sec.elements[#sec.elements+1] = el
                function el:Set(v)
                    el.value = clamp(v, el.min, el.max)
                    pcall(el.cb, el.value)
                end
                function el:Get() return el.value end
                return el
            end

            function sec:Dropdown(c)
                local el = { type="dropdown", name=c.name or "", options=c.options or {}, value=c.default or (c.options and c.options[1]) or "", cb=c.callback or function()end, open=false }
                local ez = nz()
                el._lbl  = Tx{Visible=false, Color=Theme.text_dim, Opacity=1, Size=11, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name,  ZIndex=ez}
                el._bg   = Sq{Visible=false, Filled=true,  Color=Theme.dd_bg,       Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+1}
                el._brd  = Sq{Visible=false, Filled=false, Color=Theme.section_brd, Opacity=0.5, Thickness=1, Rounding=3, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+2}
                el._val  = Tx{Visible=false, Color=Theme.text,    Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.value, ZIndex=ez+3}
                el._arr  = Tx{Visible=false, Color=Theme.text_dim, Opacity=0.8, Size=11, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text="▾",   ZIndex=ez+3}
                el._opts = {}
                for i, opt in ipairs(el.options) do
                    el._opts[i] = {
                        _bg  = Sq{Visible=false, Filled=true, Color=Theme.dd_item, Opacity=1, Rounding=0, Position=v2(0,0), Size=v2(0,22), ZIndex=500+ez+i},
                        _txt = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=opt, ZIndex=501+ez+i},
                    }
                end
                sec.elements[#sec.elements+1] = el
                function el:Set(v) el.value = v; el._val.Text = v; pcall(el.cb, v) end
                function el:Get() return el.value end
                function el:SetOptions(opts) el.options = opts end
                return el
            end

            function sec:MultiDropdown(c)
                local sel = {}
                for _, d in ipairs(c.default or {}) do sel[d] = true end
                local el = { type="multidropdown", name=c.name or "", options=c.options or {}, selected=sel, cb=c.callback or function()end, open=false }
                local ez = nz()
                el._lbl  = Tx{Visible=false, Color=Theme.text_dim, Opacity=1, Size=11, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name, ZIndex=ez}
                el._bg   = Sq{Visible=false, Filled=true,  Color=Theme.dd_bg,       Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+1}
                el._brd  = Sq{Visible=false, Filled=false, Color=Theme.section_brd, Opacity=0.5, Thickness=1, Rounding=3, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+2}
                el._val  = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text="None", ZIndex=ez+3}
                el._arr  = Tx{Visible=false, Color=Theme.text_dim, Opacity=0.8, Size=11, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text="▾", ZIndex=ez+3}
                el._opts = {}
                for i, opt in ipairs(el.options) do
                    el._opts[i] = {
                        _bg  = Sq{Visible=false, Filled=true, Color=Theme.dd_item, Opacity=1, Rounding=0, Position=v2(0,0), Size=v2(0,22), ZIndex=500+ez+i},
                        _chk = Sq{Visible=false, Filled=true, Color=Theme.tgl_off, Opacity=1, Rounding=2, Position=v2(0,0), Size=v2(10,10), ZIndex=502+ez+i},
                        _txt = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=opt, ZIndex=501+ez+i},
                    }
                end
                local function getText()
                    local ks = {}
                    for k, v in pairs(el.selected) do if v then ks[#ks+1] = k end end
                    if #ks == 0 then return "None" end
                    if #ks > 2  then return ks[1] .. " (+" .. (#ks-1) .. ")" end
                    return table.concat(ks, ", ")
                end
                el._getText = getText
                sec.elements[#sec.elements+1] = el
                function el:Get()
                    local t = {}
                    for k, v in pairs(el.selected) do if v then t[#t+1] = k end end
                    return t
                end
                function el:Set(tbl)
                    el.selected = {}
                    for _, v in ipairs(tbl) do el.selected[v] = true end
                    el._val.Text = getText()
                    pcall(el.cb, el:Get())
                end
                return el
            end

            function sec:Keybind(c)
                local el = { type="keybind", name=c.name or "", value=c.default or "Unbound", cb=c.callback or function()end, listening=false }
                local ez = nz()
                el._txt = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name, ZIndex=ez+1}
                el._bg  = Sq{Visible=false, Filled=true,  Color=Theme.kb_bg,       Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(60,18), ZIndex=ez}
                el._brd = Sq{Visible=false, Filled=false, Color=Theme.section_brd, Opacity=0.4, Thickness=1, Rounding=3, Position=v2(0,0), Size=v2(60,18), ZIndex=ez+1}
                el._val = Tx{Visible=false, Color=Theme.text_dim, Opacity=1, Size=11, Center=true, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.value, ZIndex=ez+2}
                sec.elements[#sec.elements+1] = el
                function el:Get() return el.value end
                function el:Set(k) el.value = k; el._val.Text = k end
                return el
            end

            function sec:TextInput(c)
                local el = { type="textinput", name=c.name or "", value="", placeholder=c.placeholder or "", cb=c.callback or function()end, focused=false, _blink=0 }
                local ez = nz()
                el._lbl = Tx{Visible=false, Color=Theme.text_dim, Opacity=1, Size=11, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text=el.name, ZIndex=ez}
                el._bg  = Sq{Visible=false, Filled=true,  Color=Theme.input_bg,     Opacity=1, Rounding=3, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+1}
                el._brd = Sq{Visible=false, Filled=false, Color=Theme.section_brd,  Opacity=0.4, Thickness=1, Rounding=3, Position=v2(0,0), Size=v2(0,22), ZIndex=ez+2}
                el._txt = Tx{Visible=false, Color=Theme.text, Opacity=1, Size=12, Center=false, Outline=true, OutlineColor=v3(0,0,0), Position=v2(0,0), Text="", ZIndex=ez+3}
                el._cur = Sq{Visible=false, Filled=true, Color=Theme.accent, Opacity=1, Position=v2(0,0), Size=v2(1,13), ZIndex=ez+4}
                sec.elements[#sec.elements+1] = el
                function el:Get() return el.value end
                function el:Set(s) el.value = s end
