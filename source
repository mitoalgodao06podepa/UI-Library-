function library:apply_theme(instance, theme, property)
	if themes.utility[theme] and themes.utility[theme][property] then
		insert(themes.utility[theme][property], instance)
	end
end

function library:update_theme(theme, clr)
	if not themes.utility[theme] then return end
	for prop, objects in next, themes.utility[theme] do
		for _, obj in next, objects do
			if obj and obj.Parent then
				obj[prop] = clr
			end
		end
	end
	themes.preset[theme] = clr
end

function library:connection(signal, callback)
	local conn = signal:Connect(callback)
	insert(library.connections, conn)
	return conn
end

function library:tween(obj, props)
	tween_service:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

function library:round(number, float)
	local mul = 1 / (float or 1)
	return floor(number * mul + 0.5) / mul
end

function library:convert_enum(str)
	local parts = {}
	for p in string.gmatch(str, "[%w_]+") do insert(parts, p) end
	local e = Enum
	for i = 2, #parts do e = e[parts[i]] end
	return e
end

function library:apply_stroke(parent)
	local s = Instance.new("UIStroke")
	s.Parent = parent
	s.Color = themes.preset.text_outline
	s.LineJoinMode = Enum.LineJoinMode.Miter
	library:apply_theme(s, "text_outline", "Color")
	return s
end

function library:create(class, opts)
	local ins = Instance.new(class)
	for k, v in next, opts do ins[k] = v end
	if class == "TextLabel" or class == "TextButton" or class == "TextBox" then
		library:apply_theme(ins, "text", "TextColor3")
		library:apply_stroke(ins)
	elseif class == "ScreenGui" then
		insert(library.guis, ins)
	end
	return ins
end

function library:hovering(obj)
	if type(obj) == "table" then
		for _, o in obj do if library:hovering(o) then return true end end
		return false
	end
	local py = obj.AbsolutePosition.Y <= mouse.Y and mouse.Y <= obj.AbsolutePosition.Y + obj.AbsoluteSize.Y
	local px = obj.AbsolutePosition.X <= mouse.X and mouse.X <= obj.AbsolutePosition.X + obj.AbsoluteSize.X
	return py and px
end

function library:hoverify(trigger, parent)
	local h = library:create("Frame", {
		Parent = parent, BackgroundTransparency = 1, BorderColor3 = rgb(0,0,0),
		Size = dim2(1,0,1,0), BorderSizePixel = 0,
		BackgroundColor3 = themes.preset.accent, ZIndex = 1,
	})
	library:apply_theme(h, "accent", "BackgroundColor3")
	trigger.MouseEnter:Connect(function() library:tween(h, {BackgroundTransparency = 0}) end)
	trigger.MouseLeave:Connect(function() library:tween(h, {BackgroundTransparency = 1}) end)
	return h
end

function library:draggify(frame)
	local dragging, start_pos, start = false, nil, nil
	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true
			start = input.Position
			start_pos = frame.Position
			if library.current_element_open then
				library.current_element_open.set_visible(false)
				library.current_element_open.open = false
				library.current_element_open = nil
			end
			if frame.Parent:IsA("ScreenGui") and frame.Parent.DisplayOrder ~= 999999 then
				library.display_orders += 1
				frame.Parent.DisplayOrder = library.display_orders
			end
		end
	end)
	frame.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	library:connection(uis.InputChanged, function(input)
		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
			local vx = camera.ViewportSize.X
			local vy = camera.ViewportSize.Y
			frame.Position = dim2(0,
				clamp(start_pos.X.Offset + (input.Position.X - start.X), 0, vx - frame.Size.X.Offset),
				0,
				clamp(start_pos.Y.Offset + (input.Position.Y - start.Y), 0, vy - frame.Size.Y.Offset)
			)
		end
	end)
end

function library:make_resizable(frame)
	local handle = Instance.new("TextButton")
	handle.Position = dim2(1,-10,1,-10)
	handle.Size = dim2(0,10,0,10)
	handle.BorderSizePixel = 0
	handle.BackgroundTransparency = 1
	handle.Text = ""
	handle.Parent = frame
	local resizing, start_size, start_pos = false, nil, nil
	local og = frame.Size
	handle.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			resizing = true; start_pos = input.Position; start_size = frame.Size
		end
	end)
	handle.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then resizing = false end
	end)
	library:connection(uis.InputChanged, function(input)
		if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
			frame.Size = dim2(0,
				clamp(start_size.X.Offset + (input.Position.X - start_pos.X), og.X.Offset, camera.ViewportSize.X),
				0,
				clamp(start_size.Y.Offset + (input.Position.Y - start_pos.Y), og.Y.Offset, camera.ViewportSize.Y)
			)
		end
	end)
end

