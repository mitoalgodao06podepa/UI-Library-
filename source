--[[
    SerotininLib — Drawing-based UI Library
    Rendering via Drawing API + RunService
    
    API:
        local Lib = loadstring(game:HttpGet("..."))()
        local Win = Lib.new({ title="MyScript", x=120, y=80, width=620, height=430 })
        local Tab = Win:Tab("Aimbot")
        local Sec = Tab:Section({ name="General", side="left" })

        Sec:Toggle({ name="Enabled",   default=false, callback=function(v) end })
        Sec:Button({ name="Click Me",  callback=function()   end })
        Sec:Slider({ name="Smoothing", min=0, max=100, default=75, decimals=0, callback=function(v) end })
        Sec:Dropdown({ name="Style",   options={"Spring","Linear"}, default="Spring", callback=function(v) end })
        Sec:MultiDropdown({ name="Hitboxes", options={"Head","Neck","Chest"}, default={}, callback=function(t) end })
        Sec:Keybind({ name="Aimkey",   default="T", callback=function(k) end })
        Sec:TextInput({ name="Tag",    placeholder="...", callback=function(s) end })
        Sec:ColorPicker({ name="Color",default=Color3.fromRGB(0,185,165), callback=function(c) end })
        Sec:Label({ text="v1.0.0", color=Color3.fromRGB(80,90,100) })
        Sec:Separator()

        Win:Notify({ title="Info", text="Loaded!", duration=3 })
        Win:Toggle()   -- hide/show
        Win:Destroy()
--]]

