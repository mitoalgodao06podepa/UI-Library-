				AddStroke(box, Theme.SectionBorder, 1)
				local selLabel = Make("TextLabel", {
					Size                   = UDim2.new(1, -18, 1, 0),
					Position               = UDim2.fromOffset(6, 0),
					BackgroundTransparency = 1,
					Text                   = getSelectedText(),
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.Gotham,
					TextSize               = 10,
					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 8,
					Parent                 = box,
				})
				local arrow = Make("TextLabel", {
					Size                   = UDim2.fromOffset(14, 14),
					Position               = UDim2.new(1, -16, 0.5, -7),
					BackgroundTransparency = 1,
					Text                   = "▾",
					TextColor3             = Theme.Accent,
					Font                   = Enum.Font.GothamBold,
					TextSize               = 11,
					ZIndex                 = 8,
					Parent                 = box,
				})
				local dropFrame = Make("Frame", {
					Size             = UDim2.new(1, 0, 0, 0),
					Position         = UDim2.new(0, 0, 1, 2),
					BackgroundColor3 = Theme.Dropdown_BG,
					ZIndex           = 20,
					ClipsDescendants = true,
					Visible          = false,
					Parent           = box,
				})
				AddCorner(dropFrame, 4)
				AddStroke(dropFrame, Theme.SectionBorder, 1)
				local itemList = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 0),
					AutomaticSize          = Enum.AutomaticSize.Y,
					BackgroundTransparency = 1,
					ZIndex                 = 21,
					Parent                 = dropFrame,
				})
				AddPadding(itemList, 3, 3, 3, 3)
				AddListLayout(itemList, 2)

				local totalH = #options * 22 + 6

				local function buildItems()
					for _, c in ipairs(itemList:GetChildren()) do
						if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
					end
					for _, opt in ipairs(options) do
						local isOn = selected[opt] == true
