			BackgroundColor3 = rgb(255,255,255)
		}); library:create("UIStroke", {Parent = b, LineJoinMode = Enum.LineJoinMode.Miter})
		return b
	end

	local hold_btn   = make_mode_btn("hold")
	local toggle_btn = make_mode_btn("toggle")
	local always_btn = make_mode_btn("always")

	local ug2 = library:create("UIGradient", {
		Parent = ks, Rotation = 90,
		Color = rgbseq{rgbkey(0, rgb(41,41,55)), rgbkey(1, rgb(35,35,47))}
	}); library:apply_theme(ug2, "contrast", "Color")
	library:create("UIStroke", {
		Parent = ks, Color = themes.preset.inline,
		LineJoinMode = Enum.LineJoinMode.Miter,
		ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	})

	function cfg.set_visible(b)
		ks.Visible = b
		ks.Position = dim2(0, eo.AbsolutePosition.X + 1, 0, eo.AbsolutePosition.Y + 17)
		if b then
			if library.current_element_open and library.current_element_open ~= cfg then
				library.current_element_open.set_visible(false)
				library.current_element_open.open = false
			end
			library.current_element_open = cfg
		end
	end

	function cfg.set_mode(mode)
		cfg.mode = mode
		if mode == "always" then cfg.set(true)
		elseif mode == "hold" then cfg.set(false) end
		flags[cfg.flag]["mode"] = mode
	end

	function cfg.set(input)
		if type(input) == "boolean" then
			local v2 = cfg.mode == "always" and true or input
			cfg.active = v2
			flags[cfg.flag]["active"] = v2
			cfg.callback(v2)
		elseif tostring(input):find("Enum") then
			input = input.Name == "Escape" and "none" or input
			cfg.key = input or "none"
			local t = keys[cfg.key] or tostring(cfg.key):gsub("Enum.","")
			local t2 = tostring(t):gsub("KeyCode.",""):gsub("UserInputType.","") or "none"
			cfg.key_name = t2
			flags[cfg.flag]["mode"] = cfg.mode
			flags[cfg.flag]["key"] = cfg.key
			key_tx.Text = string.lower(t2)
			cfg.callback(cfg.active or false)
		elseif find({"toggle","hold","always"}, input) then
			cfg.set_mode(input)
			if input == "always" then cfg.active = true end
			cfg.callback(cfg.active or false)
		elseif type(input) == "table" then
			input.key = type(input.key) == "string" and input.key ~= "none" and library:convert_enum(input.key) or input.key
			input.key = input.key == Enum.KeyCode.Escape and "none" or input.key
			cfg.key = input.key or "none"
			cfg.mode = input.mode or "toggle"
			if input.active then cfg.active = input.active end
			local t = tostring(cfg.key) ~= "Enums" and (keys[cfg.key] or tostring(cfg.key):gsub("Enum.","")) or nil
			local t2 = t and tostring(t):gsub("KeyCode.",""):gsub("UserInputType.","")
			key_tx.Text = string.lower(t2 or "none")
			cfg.key_name = t2
		end
		flags[cfg.flag] = {mode = cfg.mode, key = cfg.key, active = cfg.active}
		if cfg.name and KEYBIND_ELEMENT then
			KEYBIND_ELEMENT.Visible = cfg.active
			library:tween(KEYBIND_ELEMENT, {TextTransparency = cfg.active and 0 or 1})
			local t = tostring(cfg.key) ~= "Enums" and (keys[cfg.key] or tostring(cfg.key):gsub("Enum.","")) or nil
			local t2 = t and tostring(t):gsub("KeyCode.",""):gsub("UserInputType.","")
			KEYBIND_ELEMENT.Text = "[ "..string.upper(string.sub(cfg.mode,1,1))..string.sub(cfg.mode,2).." ] "..cfg.name.." - "..(t2 or "none")
		end
	end

	hold_btn.MouseButton1Click:Connect(function() cfg.set_mode("hold"); cfg.set_visible(false); cfg.open = false end)
	toggle_btn.MouseButton1Click:Connect(function() cfg.set_mode("toggle"); cfg.set_visible(false); cfg.open = false end)
	always_btn.MouseButton1Click:Connect(function() cfg.set_mode("always"); cfg.set_visible(false); cfg.open = false end)

	eo.MouseButton2Click:Connect(function()
		cfg.open = not cfg.open; cfg.set_visible(cfg.open)
	end)

	eo.MouseButton1Down:Connect(function()
		task.wait()
		key_tx.Text = "..."
		if cfg.binding then return end
		cfg.binding = library:connection(uis.InputBegan, function(input, ge)
			local sk = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
			cfg.set(sk)
			cfg.binding:Disconnect(); cfg.binding = nil
		end)
	end)

	library:connection(uis.InputBegan, function(input, ge)
		local sk = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
		if not ge and sk == cfg.key then
			if cfg.mode == "toggle" then cfg.active = not cfg.active; cfg.set(cfg.active)
			elseif cfg.mode == "hold" then cfg.set(true) end
		end
	end)

	library:connection(uis.InputEnded, function(input, ge)
		if ge then return end
		local sk = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
		if sk == cfg.key and cfg.mode == "hold" then cfg.set(false) end
	end)

	cfg.set({mode = cfg.mode, active = cfg.active, key = cfg.key})
	library.config_flags[cfg.flag] = cfg.set

	return setmetatable(cfg, library)
end

