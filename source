                local el = { type="separator" }
                local ez = nz()
                el._line = Sq{Visible=false, Filled=true, Color=Theme.sep, Opacity=0.45, Position=v2(0,0), Size=v2(0,1), ZIndex=ez}
                sec.elements[#sec.elements+1] = el
                return el
            end

            return sec
        end

        return tab
    end

