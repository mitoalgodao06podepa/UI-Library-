    function self:Toggle() self.visible = not self.visible end
    function self:Destroy()
        for _, o in ipairs(_pool) do pcall(function() o:Remove() end) end
        table.clear(_pool); table.clear(_windows); table.clear(_notifs)
    end
    function self:SetTheme(overrides)
        for k, v in pairs(overrides) do Theme[k] = v end
    end

