--  CONFIG SECTION helper (cria uma tab de configuração pronta)
-- ════════════════════════════════════════════════════════════
function Library:CreateConfigTab(windowObj, tabName)
	tabName = tabName or "Configs"
	local tab = windowObj:AddTab(tabName)
	local sec = tab:AddSection("Gerenciar Configs")

	local nameBox = sec:AddTextbox("Nome", "nome da config...")
	local configList = { "— nenhuma —" }

	local function refreshList()
		configList = Library.Config:List()
		if #configList == 0 then configList = { "— nenhuma —" } end
		dd:SetOptions(configList)
	end

	local dd = sec:AddDropdown("Config", configList, nil, function() end)

	sec:AddButton("💾  Salvar", function()
		local n = nameBox:Get()
		if n == "" then
			ShowNotif({ Title = "Configs", Text = "Digite um nome!", Color = Color3.fromRGB(220, 80, 80), Time = 2 })
			return
		end
		Library.Config:Save(n)
		refreshList()
		ShowNotif({ Title = "Configs", Text = 'Config "' .. n .. '" salva!', Time = 3 })
	end)

	sec:AddButton("📂  Carregar", function()
		local n = dd:Get()
		if n == "— nenhuma —" then return end
		local ok = Library.Config:Load(n)
		ShowNotif({
			Title = "Configs",
			Text  = ok and ('Config "' .. n .. '" carregada!') or "Erro ao carregar.",
			Color = ok and Theme.Accent or Color3.fromRGB(220, 80, 80),
			Time  = 3
		})
	end)

	sec:AddButton("🗑  Deletar", function()
		local n = dd:Get()
		if n == "— nenhuma —" then return end
		Library.Config:Delete(n)
		refreshList()
		ShowNotif({ Title = "Configs", Text = 'Config "' .. n .. '" deletada.', Time = 2 })
	end)

	sec:AddButton("🔄  Atualizar Lista", function()
		refreshList()
	end)

	refreshList()
end

return Library
