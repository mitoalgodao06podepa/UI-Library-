function library:tab(opts)
	local cfg = {name = opts.name or "Tab", enabled = false}

	if not self._mandatory_done and self._make_mandatory then
		-- tabs added by user go before mandatory; defer mandatory after first open
	end

	local btn = library:create("TextButton", {
		Parent = self.tab_holder, FontFace = library.font,
		Text = "", Name = "",
		BorderSizePixel = 0, Size = dim2(0,0,1,-2), ZIndex = 5,
