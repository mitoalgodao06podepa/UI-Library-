--  CONFIG SYSTEM
-- ════════════════════════════════════════════════════════════
local ConfigSystem = {}

function ConfigSystem:Save(name)
	local data = {}
	for flag, val in pairs(_flags) do
		if type(val) == "boolean" or type(val) == "number" or type(val) == "string" then
			data[flag] = val
		elseif type(val) == "userdata" then
			-- Color3
			local ok, r, g, b = pcall(function() return val.R, val.G, val.B end)
			if ok then data[flag] = { __type = "Color3", r = r, g = g, b = b } end
		end
	end
	local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
	if ok then
		pcall(writefile, "UILib_" .. name .. ".cfg", encoded)
		return true
	end
	return false
end

function ConfigSystem:Load(name)
	local ok, raw = pcall(readfile, "UILib_" .. name .. ".cfg")
	if not ok or not raw then return false end
	local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
	if not ok2 or not data then return false end
	for flag, val in pairs(data) do
		local setter = _cfgCallbacks[flag]
		if setter then
			if type(val) == "table" and val.__type == "Color3" then
				setter(Color3.fromRGB(val.r * 255, val.g * 255, val.b * 255))
			else
				setter(val)
			end
		end
	end
	return true
end

function ConfigSystem:List()
	local list = {}
	pcall(function()
		for _, f in ipairs(listfiles(".")) do
			local name = f:match("UILib_(.+)%.cfg$")
			if name then table.insert(list, name) end
		end
	end)
	return list
end

function ConfigSystem:Delete(name)
	pcall(delfile, "UILib_" .. name .. ".cfg")
end

Library.Config = ConfigSystem

