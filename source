		AutoButtonColor = false
	}); library:apply_theme(btn, "outline", "BackgroundColor3")

	local btn_inn = library:create("Frame", {
		Parent = btn, Size = dim2(1,-2,1,0),
		Position = dim2(0,1,0,1), BorderSizePixel = 0,
		ZIndex = 5, BackgroundColor3 = themes.preset.inline
	}); library:apply_theme(btn_inn, "inline", "BackgroundColor3")

	local btn_bg = library:create("Frame", {
		Parent = btn_inn, Size = dim2(1,-2,1,-1),
		Position = dim2(0,1,0,1), BorderSizePixel = 0,
		ZIndex = 5, BackgroundColor3 = rgb(255,255,255)
	})

	local ug = library:create("UIGradient", {
		Parent = btn_bg, Rotation = 90,
		Color = rgbseq{rgbkey(0, rgb(41,41,55)), rgbkey(1, rgb(35,35,47))}
	}); library:apply_theme(ug, "contrast", "Color")

	local tx = library:create("TextLabel", {
		Parent = btn_bg, FontFace = library.font,
		Text = cfg.name, BackgroundTransparency = 1,
		Size = dim2(1,0,1,0), BorderSizePixel = 0,
		AutomaticSize = Enum.AutomaticSize.X,
		TextSize = 12, ZIndex = 5,
		BackgroundColor3 = rgb(255,255,255)
	}); library:apply_theme(tx, "accent", "TextColor3")

	local sec_holder = library:create("Frame", {
		Parent = library.section_holder, BackgroundTransparency = 1,
		Size = dim2(1,0,1,0), BorderSizePixel = 0, Visible = false,
		BackgroundColor3 = rgb(255,255,255)
	})
	cfg["holder"] = sec_holder

	library:create("UIListLayout", {
		Parent = sec_holder,
		FillDirection = Enum.FillDirection.Horizontal,
		HorizontalFlex = Enum.UIFlexAlignment.Fill,
		Padding = dim(0,4), SortOrder = Enum.SortOrder.LayoutOrder
	})

	function cfg.open_tab()
		if library.current_tab and library.current_tab[1] ~= btn_bg then
			local old = library.current_tab[1]
			old.Size = dim2(1,-2,1,-1)
			old:FindFirstChildOfClass("UIGradient").Rotation = 90
			old:FindFirstChildOfClass("TextLabel").TextColor3 = themes.preset.text
			library.current_tab[2].Visible = false
			library.current_tab = nil
		end
		library.current_tab = {btn_bg, sec_holder}
		btn_bg.Size = dim2(1,-2,1,0)
		btn_bg:FindFirstChildOfClass("UIGradient").Rotation = -90
		btn_bg:FindFirstChildOfClass("TextLabel").TextColor3 = themes.preset.accent
		sec_holder.Visible = true
		if library.current_element_open and library.current_element_open ~= cfg then
			library.current_element_open.set_visible(false)
			library.current_element_open.open = false
			library.current_element_open = nil
		end
	end

	btn.MouseButton1Click:Connect(cfg.open_tab)

	if not self._mandatory_done and self._make_mandatory then
		local mt = getmetatable(self)
		if mt == library then
			self._mandatory_done = true
			task.defer(function()
				self._make_mandatory()
				self._make_mandatory = nil
			end)
		end
	end

	return setmetatable(cfg, library)
end

