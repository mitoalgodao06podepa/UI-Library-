		visible = opts.visible or true,
		input_disabled = opts.input or false,
		custom_color = opts.custom or nil,
		min = opts.min or opts.minimum or 0,
		max = opts.max or opts.maximum or 100,
		intervals = opts.interval or opts.decimal or 1,
		default = opts.default or 10,
		dragging = false,
		value = opts.default or 10,
	}

	local real = library:create("TextLabel", {
		Parent = self.holder, FontFace = library.font,
