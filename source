			function sectionObj:AddColorPicker(label, default, callback)
				callback = callback or function() end
				local color = default or Color3.fromRGB(0, 185, 165)
				local h, s, v = Color3.toHSV(color)
				local opened = false

				local row = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 22),
					BackgroundTransparency = 1,
					ZIndex                 = 6,
					Parent                 = sectionFrame,
				})
				Make("TextLabel", {
					Size                   = UDim2.new(0.65, 0, 1, 0),
					BackgroundTransparency = 1,
					Text                   = label,
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.Gotham,
					TextSize               = 11,
					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 7,
					Parent                 = row,
				})
				local preview = Make("TextButton", {
					Size             = UDim2.new(0.32, 0, 0.8, 0),
					Position         = UDim2.new(0.67, 0, 0.1, 0),
					BackgroundColor3 = color,
					Text             = "",
					ZIndex           = 7,
					Parent           = row,
				})
				AddCorner(preview, 3)
				AddStroke(preview, Theme.SectionBorder, 1)
				local picker = Make("Frame", {
					Size             = UDim2.new(1, 0, 0, 0),
					Position         = UDim2.new(0, 0, 1, 2),
					BackgroundColor3 = Theme.Dropdown_BG,
					ZIndex           = 20,
					ClipsDescendants = true,
					Visible          = false,
					Parent           = row,
				})
				AddCorner(picker, 4)
				AddStroke(picker, Theme.SectionBorder, 1)
				AddPadding(picker, 6, 6, 6, 6)
				AddListLayout(picker, 4)

				local function refresh()
					color = Color3.fromHSV(h, s, v)
					preview.BackgroundColor3 = color
					callback(color)
				end

				local function makeColorSlider(pLabel, initVal, cb)
					local sw = Make("Frame", {
						Size                   = UDim2.new(1, 0, 0, 28),
						BackgroundTransparency = 1,
						ZIndex                 = 21,
						Parent                 = picker,
					})
					Make("TextLabel", {
						Size                   = UDim2.new(1, 0, 0, 12),
						BackgroundTransparency = 1,
						Text                   = pLabel,
						TextColor3             = Theme.SubText,
						Font                   = Enum.Font.Gotham,
						TextSize               = 9,
						TextXAlignment         = Enum.TextXAlignment.Left,
						ZIndex                 = 22,
						Parent                 = sw,
					})
					local tr = Make("Frame", {
						Size             = UDim2.new(1, 0, 0, 6),
						Position         = UDim2.fromOffset(0, 16),
						BackgroundColor3 = Theme.Slider_Track,
						ZIndex           = 22,
						Parent           = sw,
					})
					AddCorner(tr, 99)
					local fl = Make("Frame", {
						Size             = UDim2.new(initVal, 0, 1, 0),
						BackgroundColor3 = Theme.Slider_Fill,
						ZIndex           = 23,
						Parent           = tr,
					})
					AddCorner(fl, 99)
					local hd = Make("Frame", {
						Size             = UDim2.fromOffset(10, 10),
						Position         = UDim2.new(initVal, -5, 0.5, -5),
						BackgroundColor3 = Color3.fromRGB(255, 255, 255),
						ZIndex           = 24,
						Parent           = tr,
					})
					AddCorner(hd, 99)
					local ib = Make("TextButton", {
						Size                   = UDim2.new(1, 0, 0, 16),
						Position               = UDim2.fromOffset(0, 12),
						BackgroundTransparency = 1,
						Text                   = "",
						ZIndex                 = 25,
						Parent                 = sw,
					})
					local sliding = false
					ib.MouseButton1Down:Connect(function() sliding = true end)
					UserInputService.InputChanged:Connect(function(inp)
						if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
							local p = math.clamp((UserInputService:GetMouseLocation().X - tr.AbsolutePosition.X) / tr.AbsoluteSize.X, 0, 1)
							fl.Size = UDim2.new(p, 0, 1, 0)
							hd.Position = UDim2.new(p, -5, 0.5, -5)
							cb(p)
						end
					end)
					UserInputService.InputEnded:Connect(function(inp)
						if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
					end)
				end

				makeColorSlider("Hue",        h, function(p) h = p; refresh() end)
				makeColorSlider("Saturation", s, function(p) s = p; refresh() end)
				makeColorSlider("Brightness", v, function(p) v = p; refresh() end)

				preview.MouseButton1Click:Connect(function()
					opened = not opened
					if opened then
						picker.Visible = true
						Tween(picker, { Size = UDim2.new(1, 0, 0, 110) }, 0.15, Enum.EasingStyle.Back)
					else
						Tween(picker, { Size = UDim2.new(1, 0, 0, 0) }, 0.12)
						task.delay(0.13, function() picker.Visible = false end)
					end
				end)

				local obj = {}
				function obj:Get() return color end
				function obj:Set(c)
					color = c
					h, s, v = Color3.toHSV(c)
					preview.BackgroundColor3 = c
					callback(c)
				end
				return obj
			end

