function Library:CreateWatermark(cfg)
	cfg = cfg or {}
	local text    = cfg.Text    or "UI Library"
	local subtext = cfg.SubText or ""
	local pos     = cfg.Position or UDim2.new(0, 12, 0, 12)

	local frame = Make("Frame", {
		Name             = "Watermark",
		Size             = UDim2.fromOffset(0, 28),
		AutomaticSize    = Enum.AutomaticSize.X,
		Position         = pos,
		BackgroundColor3 = Theme.WatermarkBG,
		ZIndex           = 50,
		Parent           = RootGui,
	})
	Corner(frame, 5)
	Stroke(frame, Theme.SectionBorder, 1)
	Padding(frame, 0, 10, 0, 10)

	-- barra teal em cima
	Make("Frame", {
		Size             = UDim2.new(1, 0, 0, 2),
		BackgroundColor3 = Theme.Accent,
		ZIndex           = 51,
		Parent           = frame,
	})

	local inner = Make("Frame", {
		Size                   = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		ZIndex                 = 51,
		Parent                 = frame,
	})
	ListLayout(inner, 4, Enum.FillDirection.Horizontal, nil, Enum.VerticalAlignment.Center)
	Padding(inner, 0, 0, 0, 0)

	-- ponto teal decorativo
	local dot = Make("Frame", {
		Size             = UDim2.fromOffset(6, 6),
		BackgroundColor3 = Theme.Accent,
		ZIndex           = 52,
		Parent           = inner,
	})
	Corner(dot, 99)

	local titleLbl = Make("TextLabel", {
		Size                   = UDim2.fromOffset(0, 28),
		AutomaticSize          = Enum.AutomaticSize.X,
		BackgroundTransparency = 1,
		Text                   = text,
		TextColor3             = Theme.TitleText,
		Font                   = Enum.Font.GothamBold,
		TextSize               = 12,
		ZIndex                 = 52,
		Parent                 = inner,
	})

	local subLbl
	if subtext ~= "" then
		Make("Frame", {
			Size             = UDim2.fromOffset(1, 14),
			BackgroundColor3 = Theme.SectionBorder,
			ZIndex           = 52,
			Parent           = inner,
		})
		subLbl = Make("TextLabel", {
			Size                   = UDim2.fromOffset(0, 28),
			AutomaticSize          = Enum.AutomaticSize.X,
			BackgroundTransparency = 1,
			Text                   = subtext,
			TextColor3             = Theme.SubText,
			Font                   = Enum.Font.Gotham,
			TextSize               = 11,
			ZIndex                 = 52,
			Parent                 = inner,
		})
	end

	-- drag
	local dragging, dragStart, startPos
	frame.InputBegan:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = true; dragStart = inp.Position; startPos = frame.Position
			inp.Changed:Connect(function()
				if inp.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local d = inp.Position - dragStart
			frame.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + d.X,
				startPos.Y.Scale, startPos.Y.Offset + d.Y
			)
		end
	end)

	local obj = {}

	function obj:SetText(t)
		titleLbl.Text = t
	end

	function obj:SetSubText(t)
		if subLbl then subLbl.Text = t end
	end

	function obj:SetVisible(v)
		frame.Visible = v
	end

	function obj:StartClock(prefix)
		prefix = prefix or text
		task.spawn(function()
			while frame and frame.Parent do
				titleLbl.Text = prefix .. " | " .. os.date("%H:%M:%S")
				task.wait(1)
			end
		end)
	end

	return obj
end

