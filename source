				local keyBtn = Make("TextButton", {
					Size             = UDim2.new(0.32, 0, 1, 0),
					Position         = UDim2.fromScale(0.67, 0),
					BackgroundColor3 = Theme.Input_BG,
					Text             = key == Enum.KeyCode.Unknown and "Unbound" or key.Name,
