				function obj:Get()
					local tbl = {}
					for k, v in pairs(selected) do if v then table.insert(tbl, k) end end
					return tbl
				end
				function obj:Set(tbl)
					selected = {}
					for _, v in ipairs(tbl) do selected[v] = true end
					selLabel.Text = getSelectedText()
					buildItems()
					callback(obj:Get())
				end
				function obj:SetOptions(newOpts)
					options = newOpts
					totalH  = #options * 22 + 6
					buildItems()
				end
				return obj
