	function cfg.set_visible(b)
		cp_holder.Visible = b
		if b then
			if library.current_element_open and library.current_element_open ~= cfg then
				library.current_element_open.set_visible(false)
				library.current_element_open.open = false
			end
			library.current_element_open = cfg
			cp_holder.Position = dim2(0, cpbtn.AbsolutePosition.X + 1, 0, cpbtn.AbsolutePosition.Y + 17)
		end
	end

	cpbtn.MouseButton1Click:Connect(function()
		cfg.open = not cfg.open
		cfg.set_visible(cfg.open)
	end)

	function cfg.set(clr, al)
		if clr then h, s, v = clr:ToHSV() end
		if al then a = al end
		local C = hsv(h, s, v)
		local val_pos = 1 - h
		hue_picker.Position = dim2(0, 0, val_pos, (val_pos < 1) and 0 or -4)
		alpha_picker.Position = dim2(a, (a < 1) and 0 or -4, 0, 0)
		alpha_drag.BackgroundColor3 = C
		visualize.BackgroundColor3 = C
		cpbtn_handler.BackgroundColor3 = C
		colorpicker_frame.BackgroundColor3 = hsv(h, 1, 1)
		cfg.color = C; cfg.alpha = a
		local so = (s < 1) and 0 or -3
		local vo = (1 - v < 1) and 0 or -3
		sv_picker.Position = dim2(s, so, 1 - v, vo)
		flags[cfg.flag] = {Color = C, Transparency = a}
		cfg.callback(C, a)
	end

	function cfg.update_color()
		local m = uis:GetMouseLocation()
		if dragging_sat then
			s = clamp((vec2(m.X, m.Y - gui_offset) - val.AbsolutePosition).X / val.AbsoluteSize.X, 0, 1)
			v = 1 - clamp((vec2(m.X, m.Y - gui_offset) - sat.AbsolutePosition).Y / sat.AbsoluteSize.Y, 0, 1)
		elseif dragging_hue then
			h = clamp(1 - (vec2(m.X, m.Y - gui_offset) - hue_btn.AbsolutePosition).Y / hue_btn.AbsoluteSize.Y, 0, 1)
		elseif dragging_alpha then
			a = clamp((vec2(m.X, m.Y - gui_offset) - alpha_btn.AbsolutePosition).X / alpha_btn.AbsoluteSize.X, 0, 1)
		end
		cfg.set(nil, nil)
	end

	alpha_btn.MouseButton1Down:Connect(function() dragging_alpha = true end)
	hue_btn.MouseButton1Down:Connect(function() dragging_hue = true end)
	sat.MouseButton1Down:Connect(function() dragging_sat = true end)

	uis.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging_sat = false; dragging_hue = false; dragging_alpha = false
		end
	end)

	uis.InputChanged:Connect(function(input)
		if (dragging_sat or dragging_hue or dragging_alpha) and input.UserInputType == Enum.UserInputType.MouseMovement then
			cfg.update_color()
		end
	end)

	task.spawn(function()
		while true do
			task.wait()
			if flags[cfg.flag.."_RAINBOW_FLAG"] then
				cfg.set(hsv(math.abs(math.sin(tick())), s, v), a)
			end
		end
	end)

	cfg.set(cfg.color, cfg.alpha)
	library.config_flags[cfg.flag] = cfg.set

