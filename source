-- ── Helpers ──────────────────────────────────────────────────
local function Tween(obj, props, dur, style, dir)
	local t = TweenService:Create(
		obj,
		TweenInfo.new(dur or 0.15, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
		props
	)
	t:Play(); return t
end

local function Make(class, props)
	local obj = Instance.new(class)
	for k, v in pairs(props) do
		if k ~= "Parent" then obj[k] = v end
	end
	if props.Parent then obj.Parent = props.Parent end
	return obj
end

local function Corner(parent, r)
	return Make("UICorner", { CornerRadius = UDim.new(0, r or 4), Parent = parent })
end

local function Stroke(parent, col, thick)
	local e = parent:FindFirstChildOfClass("UIStroke")
	if e then e:Destroy() end
	return Make("UIStroke", { Color = col or Theme.SectionBorder, Thickness = thick or 1, Parent = parent })
end

local function Padding(parent, t, r, b, l)
	return Make("UIPadding", {
		PaddingTop    = UDim.new(0, t or 6),
		PaddingRight  = UDim.new(0, r or 8),
		PaddingBottom = UDim.new(0, b or 6),
		PaddingLeft   = UDim.new(0, l or 8),
		Parent        = parent,
	})
end

local function ListLayout(parent, pad, dir, ha, va)
	return Make("UIListLayout", {
		Padding             = UDim.new(0, pad or 4),
		FillDirection       = dir or Enum.FillDirection.Vertical,
		HorizontalAlignment = ha  or Enum.HorizontalAlignment.Left,
		VerticalAlignment   = va  or Enum.VerticalAlignment.Top,
		SortOrder           = Enum.SortOrder.LayoutOrder,
		Parent              = parent,
	})
end

local function Ripple(btn, x, y)
	local r = Make("Frame", {
		Size = UDim2.fromOffset(0,0),
		Position = UDim2.fromOffset(x, y),
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BackgroundTransparency = 0.7,
		ZIndex = btn.ZIndex + 5,
		Parent = btn,
	})
	Corner(r, 999)
	local sz = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2
	Tween(r, { Size = UDim2.fromOffset(sz, sz), BackgroundTransparency = 1 }, 0.45)
	task.delay(0.5, function() r:Destroy() end)
end

