		Parent = colorpicker_frame, Size = dim2(0,2,0,2),
		BorderMode = Enum.BorderMode.Inset, BorderColor3 = rgb(0,0,0),
		BackgroundColor3 = rgb(255,255,255), ZIndex = 3,
