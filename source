			Text = cfg.name, BackgroundTransparency = 1,
			Size = dim2(0,0,1,-1), BorderSizePixel = 0,
			AutomaticSize = Enum.AutomaticSize.X, TextSize = 12,
			BackgroundColor3 = rgb(255,255,255)
		})
		library:create("UIListLayout", {
			Parent = left, Padding = dim(0,5),
			FillDirection = Enum.FillDirection.Horizontal
		})
	end

	local bottom = library:create("Frame", {
		Parent = real, Position = dim2(0,0,0, cfg.name and 15 or 0),
		Size = dim2(1,0,0,0), BorderSizePixel = 0,
		BackgroundColor3 = rgb(255,255,255)
	})

	local sldr = library:create("TextButton", {
		Parent = bottom, Position = dim2(0,0,0,2),
		Size = dim2(1,-1,1,12), BorderSizePixel = 0,
		BackgroundColor3 = themes.preset.outline,
		Text = "", AutoButtonColor = false,
	}); library:apply_theme(sldr, "outline", "BackgroundColor3")

	if not cfg.input_disabled then library:hoverify(real, sldr) end

	local inn = library:create("Frame", {
		Parent = sldr, Position = dim2(0,1,0,1),
		Size = dim2(1,-2,1,-2), BorderSizePixel = 0, ZIndex = 1,
		BackgroundColor3 = themes.preset.inline
	}); library:apply_theme(inn, "inline", "BackgroundColor3")

	local bg = library:create("Frame", {
		Parent = inn, Position = dim2(0,1,0,1),
		Size = dim2(1,-2,1,-2), BorderSizePixel = 0,
		BackgroundColor3 = rgb(255,255,255)
	})

	local contrast = library:create("Frame", {
		Parent = bg, Size = dim2(1,0,1,0),
		BorderSizePixel = 0, BackgroundColor3 = rgb(255,255,255)
	})

	local stext = library:create("TextLabel", {
		Parent = contrast, FontFace = library.font,
		Text = "0/100", BackgroundTransparency = 1,
		Position = dim2(0,0,0,-1), Size = dim2(1,0,1,0),
		BorderSizePixel = 0, TextSize = 12, ZIndex = 2,
		BackgroundColor3 = rgb(255,255,255)
	})

	local fill = library:create("Frame", {
		Parent = contrast, Size = dim2(0,0,1,0),
		BorderSizePixel = 0,
		BackgroundColor3 = cfg.custom_color or themes.preset.accent
	})
	if not cfg.custom_color then library:apply_theme(fill, "accent", "BackgroundColor3") end
	library:create("UIGradient", {
		Parent = fill, Rotation = 90,
		Color = rgbseq{rgbkey(0, rgb(255,255,255)), rgbkey(1, rgb(167,167,167))}
	})

	local ug = library:create("UIGradient", {
		Parent = contrast, Rotation = 90,
		Color = rgbseq{rgbkey(0, rgb(41,41,55)), rgbkey(1, rgb(35,35,47))}
	}); library:apply_theme(ug, "contrast", "Color")

	library:create("UIGradient", {
		Parent = bg, Rotation = 90,
		Color = rgbseq{rgbkey(0, rgb(255,255,255)), rgbkey(1, rgb(167,167,167))}
	})

	library:create("UIListLayout", {
		Parent = bottom, Padding = dim(0,10), SortOrder = Enum.SortOrder.LayoutOrder
	})

	function cfg.set(val)
		if type(val) == "userdata" then return end
		cfg.value = clamp(library:round(val, cfg.intervals), cfg.min, cfg.max)
		fill.Size = dim2((cfg.value - cfg.min) / (cfg.max - cfg.min), 0, 1, 0)
		stext.Text = tostring(cfg.value)..cfg.suffix.."/"..tostring(cfg.max)..cfg.suffix
		flags[cfg.flag] = cfg.value
		cfg.callback(cfg.value)
	end

	function cfg.set_element_visible(b)
		real.Visible = b
		if TEXT_LABEL then TEXT_LABEL.Visible = b end
	end

	if not cfg.input_disabled then
		library:connection(uis.InputChanged, function(input)
			if cfg.dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				local sx = (input.Position.X - sldr.AbsolutePosition.X) / sldr.AbsoluteSize.X
				cfg.set(((cfg.max - cfg.min) * sx) + cfg.min)
			end
		end)
		library:connection(uis.InputEnded, function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then cfg.dragging = false end
		end)
		sldr.MouseButton1Down:Connect(function() cfg.dragging = true end)
	end

	cfg.set(cfg.default)
	cfg.set_element_visible(cfg.visible)
	library.config_flags[cfg.flag] = cfg.set
	library.visible_flags[cfg.flag] = cfg.set_element_visible

	return setmetatable(cfg, library)
end

