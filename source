					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 7,
					Parent                 = wrapper,
				})
				local box = Make("TextButton", {
					Size             = UDim2.new(0.52, 0, 1, 0),
					Position         = UDim2.fromScale(0.47, 0),
					BackgroundColor3 = Theme.Input_BG,
					Text             = "",
					ZIndex           = 7,
					ClipsDescendants = false,
					Parent           = wrapper,
				})
				Corner(box, 3)
				Stroke(box, Theme.SectionBorder, 1)
				local selLabel = Make("TextLabel", {
					Size                   = UDim2.new(1, -18, 1, 0),
					Position               = UDim2.fromOffset(6, 0),
					BackgroundTransparency = 1,
					Text                   = selected,
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.Gotham,
					TextSize               = 10,
					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 8,
					Parent                 = box,
				})
				local arrow = Make("TextLabel", {
					Size                   = UDim2.fromOffset(14, 14),
					Position               = UDim2.new(1, -16, 0.5, -7),
					BackgroundTransparency = 1,
					Text                   = "▾",
					TextColor3             = Theme.Accent,
					Font                   = Enum.Font.GothamBold,
					TextSize               = 11,
					ZIndex                 = 8,
					Parent                 = box,
				})
				local dropFrame = Make("Frame", {
					Size             = UDim2.new(1, 0, 0, 0),
					Position         = UDim2.new(0, 0, 1, 2),
					BackgroundColor3 = Theme.Dropdown_BG,
					ZIndex           = 20,
					ClipsDescendants = true,
					Visible          = false,
					Parent           = box,
				})
				Corner(dropFrame, 4)
				Stroke(dropFrame, Theme.SectionBorder, 1)
				local itemList = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 0),
					AutomaticSize          = Enum.AutomaticSize.Y,
					BackgroundTransparency = 1,
					ZIndex                 = 21,
					Parent                 = dropFrame,
				})
				Padding(itemList, 3, 3, 3, 3)
				ListLayout(itemList, 2)

				local totalH = #options * 22 + 6

				local function buildItems()
					for _, c in ipairs(itemList:GetChildren()) do
						if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
					end
					for _, opt in ipairs(options) do
						local item = Make("TextButton", {
							Name             = opt,
							Size             = UDim2.new(1, 0, 0, 20),
							BackgroundColor3 = opt == selected and Theme.Dropdown_Hover or Theme.Dropdown_Item,
							Text             = "",
							ZIndex           = 22,
							Parent           = itemList,
						})
						Corner(item, 3)
						Make("TextLabel", {
							Size                   = UDim2.new(1, -8, 1, 0),
							Position               = UDim2.fromOffset(6, 0),
							BackgroundTransparency = 1,
							Text                   = opt,
							TextColor3             = opt == selected and Color3.fromRGB(255,255,255) or Theme.Text,
							Font                   = Enum.Font.Gotham,
							TextSize               = 10,
							TextXAlignment         = Enum.TextXAlignment.Left,
							ZIndex                 = 23,
							Parent                 = item,
						})
						item.MouseEnter:Connect(function()
							if opt ~= selected then Tween(item, { BackgroundColor3 = Color3.fromRGB(36, 42, 52) }, 0.08) end
						end)
						item.MouseLeave:Connect(function()
							if opt ~= selected then Tween(item, { BackgroundColor3 = Theme.Dropdown_Item }, 0.08) end
						end)
						item.MouseButton1Click:Connect(function()
							selected = opt; selLabel.Text = opt
							opened = false
							Tween(dropFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.12)
							task.delay(0.13, function() dropFrame.Visible = false end)
							Tween(arrow, { Rotation = 0 }, 0.12)
							buildItems()
							if flag then _flags[flag] = selected end
							callback(selected)
						end)
					end
				end
				buildItems()

				box.MouseButton1Click:Connect(function()
					opened = not opened
					if opened then
						dropFrame.Visible = true
						Tween(dropFrame, { Size = UDim2.new(1, 0, 0, totalH) }, 0.15, Enum.EasingStyle.Back)
						Tween(arrow, { Rotation = 180 }, 0.12)
					else
						Tween(dropFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.12)
						Tween(arrow, { Rotation = 0 }, 0.12)
						task.delay(0.13, function() dropFrame.Visible = false end)
					end
				end)

				local obj2 = {}
				function obj2:Set(v)   selected = v; selLabel.Text = v; buildItems(); if flag then _flags[flag] = v end; callback(v) end
				function obj2:Get()    return selected end
				function obj2:SetOptions(o) options = o; totalH = #o * 22 + 6; buildItems() end

				if flag then
					_flags[flag]        = selected
					_cfgCallbacks[flag] = function(v) obj2:Set(v) end
				end
				return obj2
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  MULTI DROPDOWN                                  │
			-- └──────────────────────────────────────────────────┘
			function sec:AddMultiDropdown(label, options, defaults, callback, flag)
				callback = callback or function() end
				local selected = {}
				for _, d in ipairs(defaults or {}) do selected[d] = true end
				local opened = false

				local function getText()
					local keys = {}
					for k, v in pairs(selected) do if v then table.insert(keys, k) end end
					if #keys == 0 then return "None" end
					if #keys > 2  then return keys[1] .. " (+" .. (#keys-1) .. ")" end
					return table.concat(keys, ", ")
				end

				local wrapper = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, ZIndex = 6, Parent = sframe
				})
				Make("TextLabel", {
					Size = UDim2.new(0.45, 0, 1, 0), BackgroundTransparency = 1, Text = label,
					TextColor3 = Theme.Text, Font = Enum.Font.Gotham, TextSize = 11,
					TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7, Parent = wrapper
				})
				local box = Make("TextButton", {
					Size = UDim2.new(0.52, 0, 1, 0), Position = UDim2.fromScale(0.47, 0),
					BackgroundColor3 = Theme.Input_BG, Text = "", ZIndex = 7, Parent = wrapper
				})
				Corner(box, 3); Stroke(box, Theme.SectionBorder, 1)
				local selLabel = Make("TextLabel", {
					Size = UDim2.new(1, -18, 1, 0), Position = UDim2.fromOffset(6, 0),
					BackgroundTransparency = 1, Text = getText(), TextColor3 = Theme.Text,
					Font = Enum.Font.Gotham, TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left,
					ZIndex = 8, Parent = box
				})
				local arrow = Make("TextLabel", {
					Size = UDim2.fromOffset(14, 14), Position = UDim2.new(1, -16, 0.5, -7),
					BackgroundTransparency = 1, Text = "▾", TextColor3 = Theme.Accent,
					Font = Enum.Font.GothamBold, TextSize = 11, ZIndex = 8, Parent = box
				})
				local dropFrame = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 1, 2),
					BackgroundColor3 = Theme.Dropdown_BG, ZIndex = 20, ClipsDescendants = true,
					Visible = false, Parent = box
				})
				Corner(dropFrame, 4); Stroke(dropFrame, Theme.SectionBorder, 1)
				local itemList = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
					BackgroundTransparency = 1, ZIndex = 21, Parent = dropFrame
				})
				Padding(itemList, 3, 3, 3, 3); ListLayout(itemList, 2)

				local totalH = #options * 22 + 6

				local function buildItems()
					for _, c in ipairs(itemList:GetChildren()) do
						if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
					end
					for _, opt in ipairs(options) do
						local isOn = selected[opt] == true
						local item = Make("TextButton", {
							Name = opt, Size = UDim2.new(1, 0, 0, 20),
							BackgroundColor3 = Theme.Dropdown_Item, Text = "", ZIndex = 22, Parent = itemList
						})
						Corner(item, 3)
						local chk = Make("Frame", {
							Size = UDim2.fromOffset(12, 12), Position = UDim2.fromOffset(4, 4),
							BackgroundColor3 = isOn and Theme.Accent or Theme.Toggle_Off, ZIndex = 23, Parent = item
						})
						Corner(chk, 2); Stroke(chk, isOn and Theme.AccentLight or Theme.SectionBorder, 1)
						if isOn then
							Make("TextLabel", {
								Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = "✓",
								TextColor3 = Color3.fromRGB(255,255,255), Font = Enum.Font.GothamBold,
								TextSize = 9, ZIndex = 24, Parent = chk
							})
						end
						Make("TextLabel", {
							Size = UDim2.new(1, -22, 1, 0), Position = UDim2.fromOffset(20, 0),
							BackgroundTransparency = 1, Text = opt,
							TextColor3 = isOn and Color3.fromRGB(255,255,255) or Theme.Text,
							Font = Enum.Font.Gotham, TextSize = 10,
							TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 23, Parent = item
						})
						item.MouseEnter:Connect(function() Tween(item, { BackgroundColor3 = Color3.fromRGB(36, 42, 52) }, 0.08) end)
						item.MouseLeave:Connect(function() Tween(item, { BackgroundColor3 = Theme.Dropdown_Item }, 0.08) end)
						item.MouseButton1Click:Connect(function()
							selected[opt] = not selected[opt]
							selLabel.Text = getText(); buildItems()
							local tbl = {}
							for k, v in pairs(selected) do if v then table.insert(tbl, k) end end
							if flag then _flags[flag] = tbl end
							callback(tbl)
						end)
					end
				end
				buildItems()

				box.MouseButton1Click:Connect(function()
					opened = not opened
					if opened then
						dropFrame.Visible = true
						Tween(dropFrame, { Size = UDim2.new(1, 0, 0, totalH) }, 0.15, Enum.EasingStyle.Back)
						Tween(arrow, { Rotation = 180 }, 0.12)
					else
						Tween(dropFrame, { Size = UDim2.new(1, 0, 0, 0) }, 0.12)
						Tween(arrow, { Rotation = 0 }, 0.12)
						task.delay(0.13, function() dropFrame.Visible = false end)
					end
				end)

				local obj2 = {}
				function obj2:Get()
					local tbl = {}
					for k, v in pairs(selected) do if v then table.insert(tbl, k) end end
					return tbl
				end
				function obj2:Set(tbl)
					selected = {}
					for _, v in ipairs(tbl) do selected[v] = true end
					selLabel.Text = getText(); buildItems()
					if flag then _flags[flag] = tbl end; callback(obj2:Get())
				end
				function obj2:SetOptions(o) options = o; totalH = #o * 22 + 6; buildItems() end

				if flag then
					_flags[flag]        = {}
					_cfgCallbacks[flag] = function(v) if type(v) == "table" then obj2:Set(v) end end
				end
				return obj2
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  TEXTBOX                                         │
			-- └──────────────────────────────────────────────────┘
			function sec:AddTextbox(label, placeholder, callback, flag)
				callback    = callback    or function() end
				placeholder = placeholder or ""

				local row = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, ZIndex = 6, Parent = sframe
				})
				Make("TextLabel", {
					Size = UDim2.new(0.45, 0, 1, 0), BackgroundTransparency = 1, Text = label,
					TextColor3 = Theme.Text, Font = Enum.Font.Gotham, TextSize = 11,
					TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7, Parent = row
				})
				local box = Make("TextBox", {
					Size = UDim2.new(0.52, 0, 1, 0), Position = UDim2.fromScale(0.47, 0),
					BackgroundColor3 = Theme.Input_BG, Text = "", PlaceholderText = placeholder,
					PlaceholderColor3 = Theme.SubText, TextColor3 = Theme.Accent,
					Font = Enum.Font.GothamSemibold, TextSize = 11, ClearTextOnFocus = false,
					ZIndex = 7, Parent = row
				})
				Corner(box, 3); Stroke(box, Theme.SectionBorder, 1); Padding(box, 0, 6, 0, 6)
				box.Focused:Connect(function()
					Tween(box, { BackgroundColor3 = Color3.fromRGB(22, 28, 36) }, 0.1)
					Stroke(box, Theme.Accent, 1)
				end)
				box.FocusLost:Connect(function(enter)
					Tween(box, { BackgroundColor3 = Theme.Input_BG }, 0.1)
					Stroke(box, Theme.SectionBorder, 1)
					if flag then _flags[flag] = box.Text end
					if enter then callback(box.Text) end
				end)

				local obj2 = {}
				function obj2:Get() return box.Text end
				function obj2:Set(v) box.Text = v; if flag then _flags[flag] = v end end

				if flag then
					_flags[flag]        = ""
					_cfgCallbacks[flag] = function(v) obj2:Set(v) end
				end
				return obj2
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  KEYBIND                                         │
			-- └──────────────────────────────────────────────────┘
			function sec:AddKeybind(label, default, callback, flag, mode)
				callback = callback or function() end
				mode     = mode     or "toggle"   -- "toggle" | "hold"
				local key     = default or Enum.KeyCode.Unknown
				local binding = false
				local active  = false

				local row = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, ZIndex = 6, Parent = sframe
				})
				Make("TextLabel", {
					Size = UDim2.new(0.58, 0, 1, 0), BackgroundTransparency = 1, Text = label,
					TextColor3 = Theme.Text, Font = Enum.Font.Gotham, TextSize = 11,
					TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7, Parent = row
				})
				local modeBtn = Make("TextButton", {
					Size = UDim2.new(0.18, 0, 1, 0), Position = UDim2.fromScale(0.59, 0),
					BackgroundColor3 = Theme.Input_BG, Text = mode,
					TextColor3 = Theme.SubText, Font = Enum.Font.Gotham, TextSize = 9,
					ZIndex = 7, Parent = row
				})
				Corner(modeBtn, 3); Stroke(modeBtn, Theme.SectionBorder, 1)
				local keyBtn = Make("TextButton", {
					Size = UDim2.new(0.20, 0, 1, 0), Position = UDim2.fromScale(0.79, 0),
					BackgroundColor3 = Theme.Input_BG,
					Text = key == Enum.KeyCode.Unknown and "None" or key.Name,
					TextColor3 = Theme.Accent, Font = Enum.Font.GothamBold, TextSize = 10,
					ZIndex = 7, Parent = row
				})
				Corner(keyBtn, 3); Stroke(keyBtn, Theme.SectionBorder, 1)

				-- alterna modo
				modeBtn.MouseButton1Click:Connect(function()
					mode = mode == "toggle" and "hold" or "toggle"
					modeBtn.Text = mode
				end)

				keyBtn.MouseButton1Click:Connect(function()
					binding = true; keyBtn.Text = "..."; keyBtn.TextColor3 = Theme.AccentLight
				end)

				UserInputService.InputBegan:Connect(function(inp, gp)
					if binding and not gp and inp.UserInputType == Enum.UserInputType.Keyboard then
						key = inp.KeyCode
						keyBtn.Text = key.Name; keyBtn.TextColor3 = Theme.Accent
						binding = false
						if flag then _flags[flag] = { key = key.Name, mode = mode } end
						-- atualiza keybind list
						if keybindList then
							keybindList:_UpdateEntry(label, key.Name, mode)
						end
						callback(active)
						return
					end
					if not gp and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == key then
						if mode == "toggle" then
							active = not active
							if flag then _flags[flag] = { key = key.Name, mode = mode, active = active } end
							callback(active)
						elseif mode == "hold" then
							active = true
							if flag then _flags[flag] = { key = key.Name, mode = mode, active = true } end
							callback(true)
						end
					end
				end)

				UserInputService.InputEnded:Connect(function(inp)
					if mode == "hold" and inp.UserInputType == Enum.UserInputType.Keyboard and inp.KeyCode == key then
						active = false
						if flag then _flags[flag] = { key = key.Name, mode = mode, active = false } end
						callback(false)
					end
				end)

				-- adiciona na keybind list
				if keybindList and label and label ~= "" then
					keybindList:_AddEntry(label, key == Enum.KeyCode.Unknown and "None" or key.Name, mode)
				end

				local obj2 = {}
				function obj2:Get() return active end
				function obj2:GetKey() return key end
				function obj2:Set(k)
					key = k; keyBtn.Text = k.Name
					if keybindList then keybindList:_UpdateEntry(label, k.Name, mode) end
				end

				if flag then
					_flags[flag]        = { key = key.Name, mode = mode, active = active }
					_cfgCallbacks[flag] = function(v)
						if type(v) == "table" and v.key then
							local ok, kc = pcall(function() return Enum.KeyCode[v.key] end)
							if ok and kc then obj2:Set(kc) end
						end
					end
				end
				return obj2
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  COLOR PICKER  (com Rainbow!)                    │
			-- └──────────────────────────────────────────────────┘
			function sec:AddColorPicker(label, default, callback, flag)
				callback = callback or function() end
				local color  = default or Color3.fromRGB(0, 185, 165)
				local h, s, v = Color3.toHSV(color)
				local opened = false
				local rainbow = false
				local rbConn

				local row = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 22), BackgroundTransparency = 1, ZIndex = 6, Parent = sframe
				})
				Make("TextLabel", {
					Size = UDim2.new(0.62, 0, 1, 0), BackgroundTransparency = 1, Text = label,
					TextColor3 = Theme.Text, Font = Enum.Font.Gotham, TextSize = 11,
					TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 7, Parent = row
				})
				-- botão rainbow
				local rbBtn = Make("TextButton", {
					Size = UDim2.fromOffset(20, 18), Position = UDim2.new(0.62, 0, 0.1, 0),
					BackgroundColor3 = Theme.Input_BG, Text = "⟳",
					TextColor3 = Theme.SubText, Font = Enum.Font.GothamBold, TextSize = 10,
					ZIndex = 7, Parent = row
				})
				Corner(rbBtn, 3); Stroke(rbBtn, Theme.SectionBorder, 1)

				local preview = Make("TextButton", {
					Size = UDim2.new(0.30, -24, 0.8, 0), Position = UDim2.new(0.66, 24, 0.1, 0),
					BackgroundColor3 = color, Text = "", ZIndex = 7, Parent = row
				})
				Corner(preview, 3); Stroke(preview, Theme.SectionBorder, 1)

				local picker = Make("Frame", {
					Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 1, 2),
					BackgroundColor3 = Theme.Dropdown_BG, ZIndex = 20,
					ClipsDescendants = true, Visible = false, Parent = row
				})
				Corner(picker, 4); Stroke(picker, Theme.SectionBorder, 1)
				Padding(picker, 6, 6, 6, 6); ListLayout(picker, 4)

				local function refresh()
					color = Color3.fromHSV(h, s, v)
					preview.BackgroundColor3 = color
					if flag then _flags[flag] = color end
					callback(color)
				end

				local sliderObjs = {}
				local function makeColorSlider(slLabel, initVal, cb)
					local sw = Make("Frame", {
						Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 1, ZIndex = 21, Parent = picker
					})
					Make("TextLabel", {
						Size = UDim2.new(1, 0, 0, 12), BackgroundTransparency = 1, Text = slLabel,
						TextColor3 = Theme.SubText, Font = Enum.Font.Gotham, TextSize = 9,
						TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 22, Parent = sw
					})
					local tr = Make("Frame", {
						Size = UDim2.new(1, 0, 0, 5), Position = UDim2.fromOffset(0, 16),
						BackgroundColor3 = Theme.Slider_Track, ZIndex = 22, Parent = sw
					})
					Corner(tr, 99)
					local fl = Make("Frame", {
						Size = UDim2.new(initVal, 0, 1, 0), BackgroundColor3 = Theme.Slider_Fill, ZIndex = 23, Parent = tr
					})
					Corner(fl, 99)
					local hd = Make("Frame", {
						Size = UDim2.fromOffset(10, 10), Position = UDim2.new(initVal, -5, 0.5, -5),
						BackgroundColor3 = Color3.fromRGB(255,255,255), ZIndex = 24, Parent = tr
					})
					Corner(hd, 99)
					local ib = Make("TextButton", {
						Size = UDim2.new(1, 0, 0, 16), Position = UDim2.fromOffset(0, 12),
						BackgroundTransparency = 1, Text = "", ZIndex = 25, Parent = sw
					})
					local sliding = false
					ib.MouseButton1Down:Connect(function() sliding = true end)
					UserInputService.InputChanged:Connect(function(inp)
						if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
							local p = math.clamp((UserInputService:GetMouseLocation().X - tr.AbsolutePosition.X) / math.max(tr.AbsoluteSize.X, 1), 0, 1)
							fl.Size = UDim2.new(p, 0, 1, 0)
							hd.Position = UDim2.new(p, -5, 0.5, -5)
							cb(p)
						end
					end)
					UserInputService.InputEnded:Connect(function(inp)
						if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
					end)
					table.insert(sliderObjs, { fl = fl, hd = hd })
				end

				makeColorSlider("Hue",        h, function(p) h = p; refresh() end)
				makeColorSlider("Saturation", s, function(p) s = p; refresh() end)
				makeColorSlider("Brightness", v, function(p) v = p; refresh() end)

				-- Rainbow toggle
				rbBtn.MouseButton1Click:Connect(function()
					rainbow = not rainbow
					Tween(rbBtn, { TextColor3 = rainbow and Theme.AccentLight or Theme.SubText }, 0.15)
					if rainbow then
						rbConn = RunService.Heartbeat:Connect(function()
							h = (h + 0.002) % 1
							refresh()
							if sliderObjs[1] then
								sliderObjs[1].fl.Size = UDim2.new(h, 0, 1, 0)
								sliderObjs[1].hd.Position = UDim2.new(h, -5, 0.5, -5)
							end
						end)
					else
						if rbConn then rbConn:Disconnect(); rbConn = nil end
					end
				end)

				preview.MouseButton1Click:Connect(function()
					opened = not opened
					if opened then
						picker.Visible = true
						Tween(picker, { Size = UDim2.new(1, 0, 0, 118) }, 0.15, Enum.EasingStyle.Back)
					else
						Tween(picker, { Size = UDim2.new(1, 0, 0, 0) }, 0.12)
						task.delay(0.13, function() picker.Visible = false end)
					end
				end)

				local obj2 = {}
				function obj2:Get() return color end
				function obj2:Set(c)
					color = c; h, s, v = Color3.toHSV(c)
					preview.BackgroundColor3 = c
					if flag then _flags[flag] = c end; callback(c)
				end

				if flag then
					_flags[flag]        = color
					_cfgCallbacks[flag] = function(v)
						if typeof(v) == "Color3" then obj2:Set(v) end
					end
				end
				return obj2
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  LABEL                                           │
			-- └──────────────────────────────────────────────────┘
			function sec:AddLabel(text)
				local lbl = Make("TextLabel", {
					Size = UDim2.new(1, 0, 0, 16), BackgroundTransparency = 1, Text = text,
					TextColor3 = Theme.SubText, Font = Enum.Font.Gotham, TextSize = 10,
					TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 6, Parent = sframe
				})
				local obj2 = {}
				function obj2:Set(t) lbl.Text = t end
				function obj2:Get() return lbl.Text end
				function obj2:SetColor(c) lbl.TextColor3 = c end
				return obj2
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  SEPARATOR                                       │
			-- └──────────────────────────────────────────────────┘
			function sec:AddSeparator()
				Make("Frame", {
					Size = UDim2.new(1, 0, 0, 1), BackgroundColor3 = Theme.SectionBorder, ZIndex = 6, Parent = sframe
				})
			end

			-- ┌──────────────────────────────────────────────────┐
			-- │  TOOLTIP (standalone)                            │
			-- └──────────────────────────────────────────────────┘
			function sec:AddTooltip(targetObj, text)
				local tt = Make("TextLabel", {
					Size = UDim2.fromOffset(0, 22), AutomaticSize = Enum.AutomaticSize.X,
					BackgroundColor3 = Theme.Dropdown_BG, Text = "  " .. text .. "  ",
					TextColor3 = Theme.SubText, Font = Enum.Font.Gotham, TextSize = 10,
					ZIndex = 200, Visible = false, Parent = RootGui
				})
				Corner(tt, 3); Stroke(tt, Theme.SectionBorder, 1)
				targetObj.MouseEnter:Connect(function() tt.Visible = true end)
				targetObj.MouseLeave:Connect(function() tt.Visible = false end)
				UserInputService.InputChanged:Connect(function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseMovement and tt.Visible then
						tt.Position = UDim2.fromOffset(inp.Position.X + 12, inp.Position.Y + 12)
					end
				end)
			end

			return sec
		end -- AddSection

		return tabObj
	end -- AddTab

	-- ── Notify (window level) ─────────────────────────────────
	function WindowObj:Notify(c) ShowNotif(c) end

	-- animate in
	Tween(Window, { Size = size }, 0.3, Enum.EasingStyle.Back)

	return WindowObj
end -- CreateWindow

