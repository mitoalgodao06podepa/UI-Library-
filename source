local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService       = game:GetService("RunService")
local Players          = game:GetService("Players")

local function Tween(obj, props, duration, style, dir)
	duration = duration or 0.15
	style    = style    or Enum.EasingStyle.Quad
	dir      = dir      or Enum.EasingDirection.Out
	local t  = TweenService:Create(obj, TweenInfo.new(duration, style, dir), props)
	t:Play()
	return t
end

local function Make(class, props)
	local obj = Instance.new(class)
	for k, v in pairs(props) do
		if k ~= "Parent" then obj[k] = v end
	end
	if props.Parent then obj.Parent = props.Parent end
	return obj
end

local function AddCorner(parent, radius)
	return Make("UICorner", { CornerRadius = UDim.new(0, radius or 4), Parent = parent })
end

local function AddStroke(parent, color, thickness)
	local existing = parent:FindFirstChildOfClass("UIStroke")
	if existing then existing:Destroy() end
	return Make("UIStroke", { Color = color or Theme.SectionBorder, Thickness = thickness or 1, Parent = parent })
end

local function AddPadding(parent, top, right, bottom, left)
	return Make("UIPadding", {
		PaddingTop    = UDim.new(0, top    or 6),
		PaddingRight  = UDim.new(0, right  or 8),
		PaddingBottom = UDim.new(0, bottom or 6),
		PaddingLeft   = UDim.new(0, left   or 8),
		Parent        = parent,
	})
end

local function AddListLayout(parent, padding, dir, halign, valign)
	return Make("UIListLayout", {
		Padding             = UDim.new(0, padding or 4),
		FillDirection       = dir    or Enum.FillDirection.Vertical,
		HorizontalAlignment = halign or Enum.HorizontalAlignment.Left,
		VerticalAlignment   = valign or Enum.VerticalAlignment.Top,
		SortOrder           = Enum.SortOrder.LayoutOrder,
		Parent              = parent,
	})
end

local function RippleEffect(button, x, y)
	local ripple = Make("Frame", {
		Size                   = UDim2.fromOffset(0, 0),
		Position               = UDim2.fromOffset(x, y),
		AnchorPoint            = Vector2.new(0.5, 0.5),
		BackgroundColor3       = Color3.fromRGB(255, 255, 255),
		BackgroundTransparency = 0.7,
		ZIndex                 = button.ZIndex + 5,
		Parent                 = button,
	})
	AddCorner(ripple, 999)
	local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2
	Tween(ripple, { Size = UDim2.fromOffset(size, size), BackgroundTransparency = 1 }, 0.45, Enum.EasingStyle.Quad)
	task.delay(0.5, function() ripple:Destroy() end)
end

function Library:CreateWindow(cfg)
	cfg = cfg or {}
	local title = cfg.Title or "SerotininLib"
	local size  = cfg.Size  or UDim2.fromOffset(520, 420)

	local ScreenGui = Make("ScreenGui", {
		Name           = "SerotininLib_" .. title,
		ResetOnSpawn   = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		Parent         = (RunService:IsStudio() and Players.LocalPlayer:FindFirstChild("PlayerGui"))
		                 or game:GetService("CoreGui"),
	})

	local Window = Make("Frame", {
		Name             = "Window",
		Size             = size,
		Position         = UDim2.fromScale(0.5, 0.5),
		AnchorPoint      = Vector2.new(0.5, 0.5),
		BackgroundColor3 = Theme.Background,
		ClipsDescendants = true,
		ZIndex           = 1,
		Parent           = ScreenGui,
	})
	AddCorner(Window, 6)
	AddStroke(Window, Theme.SectionBorder, 1)

	local TitleBar = Make("Frame", {
		Name             = "TitleBar",
		Size             = UDim2.new(1, 0, 0, 32),
		BackgroundColor3 = Theme.TitleBar,
		ZIndex           = 2,
		Parent           = Window,
	})
	Make("Frame", {
		Size             = UDim2.new(1, 0, 0, 1),
		Position         = UDim2.new(0, 0, 1, -1),
		BackgroundColor3 = Theme.TitleBarLine,
		ZIndex           = 3,
		Parent           = TitleBar,
	})
	local dot = Make("Frame", {
		Size             = UDim2.fromOffset(8, 8),
		Position         = UDim2.fromOffset(10, 12),
		BackgroundColor3 = Theme.Accent,
		ZIndex           = 3,
		Parent           = TitleBar,
	})
	AddCorner(dot, 99)
	Make("TextLabel", {
		Size                   = UDim2.new(1, -80, 1, 0),
		Position               = UDim2.fromOffset(24, 0),
		BackgroundTransparency = 1,
		Text                   = title,
		TextColor3             = Theme.TitleText,
		TextXAlignment         = Enum.TextXAlignment.Left,
		Font                   = Enum.Font.GothamBold,
		TextSize               = 13,
		ZIndex                 = 3,
		Parent                 = TitleBar,
	})

	local function MakeTitleBtn(label, xOff, col)
		local btn = Make("TextButton", {
			Size             = UDim2.fromOffset(14, 14),
			Position         = UDim2.new(1, xOff, 0.5, -7),
			BackgroundColor3 = col,
			Text             = "",
			ZIndex           = 4,
			Parent           = TitleBar,
		})
		AddCorner(btn, 99)
		Make("TextLabel", {
			Size                   = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			Text                   = label,
			TextColor3             = Color3.fromRGB(255, 255, 255),
			Font                   = Enum.Font.GothamBold,
			TextSize               = 9,
			ZIndex                 = 5,
			Parent                 = btn,
		})
		return btn
	end

	local CloseBtn = MakeTitleBtn("×", -16, Theme.CloseBtn)
	local MinBtn   = MakeTitleBtn("−", -34, Theme.MinBtn)

	CloseBtn.MouseButton1Click:Connect(function()
		Tween(Window, { Size = UDim2.fromOffset(Window.AbsoluteSize.X, 0), BackgroundTransparency = 1 }, 0.2)
		task.delay(0.22, function() ScreenGui:Destroy() end)
	end)

	local minimised = false
	local normalSize = size
	MinBtn.MouseButton1Click:Connect(function()
		minimised = not minimised
		if minimised then
			normalSize = Window.Size
			Tween(Window, { Size = UDim2.fromOffset(Window.AbsoluteSize.X, 32) }, 0.2)
		else
			Tween(Window, { Size = normalSize }, 0.2)
		end
	end)

	local dragging, dragInput, dragStart, startPos
	TitleBar.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging  = true
			dragStart = input.Position
			startPos  = Window.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	TitleBar.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			local delta = input.Position - dragStart
			Window.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
		end
	end)

	local TabBar = Make("Frame", {
		Name             = "TabBar",
		Size             = UDim2.new(1, 0, 0, 28),
		Position         = UDim2.fromOffset(0, 32),
		BackgroundColor3 = Theme.SidebarBG,
		ZIndex           = 2,
		Parent           = Window,
	})
	Make("Frame", {
		Size             = UDim2.new(1, 0, 0, 1),
		Position         = UDim2.new(0, 0, 1, -1),
		BackgroundColor3 = Theme.SectionBorder,
		ZIndex           = 3,
		Parent           = TabBar,
	})
	local TabList = Make("Frame", {
		Size                   = UDim2.new(1, -8, 1, 0),
		Position               = UDim2.fromOffset(4, 0),
		BackgroundTransparency = 1,
		ZIndex                 = 3,
		Parent                 = TabBar,
	})
	AddListLayout(TabList, 2, Enum.FillDirection.Horizontal, nil, Enum.VerticalAlignment.Center)

	local ContentArea = Make("Frame", {
		Name                   = "ContentArea",
		Size                   = UDim2.new(1, 0, 1, -60),
		Position               = UDim2.fromOffset(0, 60),
		BackgroundTransparency = 1,
		ClipsDescendants       = true,
		ZIndex                 = 2,
		Parent                 = Window,
	})

	local WindowObj  = { _tabs = {}, _activeTab = nil, _gui = ScreenGui }
	local tabButtons = {}

	local function activateTab(tabObj)
		if WindowObj._activeTab then
			WindowObj._activeTab._container.Visible = false
			local oldBtn = tabButtons[WindowObj._activeTab]
			if oldBtn then
				Tween(oldBtn, { BackgroundColor3 = Theme.TabBG }, 0.1)
				oldBtn:FindFirstChild("Label").TextColor3 = Theme.TabText
				local ind = oldBtn:FindFirstChild("Indicator")
				if ind then ind.BackgroundTransparency = 1 end
			end
		end
		WindowObj._activeTab = tabObj
		tabObj._container.Visible = true
		local btn = tabButtons[tabObj]
		if btn then
			Tween(btn, { BackgroundColor3 = Theme.TabActive }, 0.12)
			btn:FindFirstChild("Label").TextColor3 = Theme.TabActiveText
			local ind = btn:FindFirstChild("Indicator")
			if ind then Tween(ind, { BackgroundTransparency = 0 }, 0.12) end
		end
	end

	function WindowObj:AddTab(name)
		local btn = Make("TextButton", {
			Name             = name .. "Btn",
			Size             = UDim2.fromOffset(0, 22),
			AutomaticSize    = Enum.AutomaticSize.X,
			BackgroundColor3 = Theme.TabBG,
			Text             = "",
			ZIndex           = 4,
			Parent           = TabList,
		})
		AddCorner(btn, 3)
		AddPadding(btn, 0, 10, 0, 10)
		Make("TextLabel", {
			Name                   = "Label",
			Size                   = UDim2.fromScale(1, 1),
			AutomaticSize          = Enum.AutomaticSize.X,
			BackgroundTransparency = 1,
			Text                   = name,
			TextColor3             = Theme.TabText,
			Font                   = Enum.Font.GothamSemibold,
			TextSize               = 11,
			ZIndex                 = 5,
			Parent                 = btn,
		})
		local ind = Make("Frame", {
			Name                   = "Indicator",
			Size                   = UDim2.new(1, 0, 0, 2),
			Position               = UDim2.new(0, 0, 1, -2),
			BackgroundColor3       = Theme.AccentLight,
			BackgroundTransparency = 1,
			ZIndex                 = 6,
			Parent                 = btn,
		})

		local container = Make("ScrollingFrame", {
			Name                 = "Tab_" .. name,
			Size                 = UDim2.fromScale(1, 1),
			BackgroundTransparency = 1,
			ScrollBarThickness   = 3,
			ScrollBarImageColor3 = Theme.Scrollbar,
			CanvasSize           = UDim2.fromOffset(0, 0),
			AutomaticCanvasSize  = Enum.AutomaticSize.Y,
			Visible              = false,
			ZIndex               = 3,
			Parent               = ContentArea,
		})
		AddPadding(container, 8, 8, 8, 8)
		AddListLayout(container, 6)

		local tabObj = { _container = container }
		tabButtons[tabObj] = btn
		table.insert(self._tabs, tabObj)

		btn.MouseButton1Click:Connect(function() activateTab(tabObj) end)
		btn.MouseEnter:Connect(function()
			if WindowObj._activeTab ~= tabObj then
				Tween(btn, { BackgroundColor3 = Color3.fromRGB(44, 48, 56) }, 0.1)
			end
		end)
		btn.MouseLeave:Connect(function()
			if WindowObj._activeTab ~= tabObj then
				Tween(btn, { BackgroundColor3 = Theme.TabBG }, 0.1)
			end
		end)

		if #self._tabs == 1 then activateTab(tabObj) end

		function tabObj:AddSection(sname)
			local sectionFrame = Make("Frame", {
				Name             = "Section_" .. sname,
				Size             = UDim2.new(1, 0, 0, 0),
				AutomaticSize    = Enum.AutomaticSize.Y,
				BackgroundColor3 = Theme.Section,
				ZIndex           = 4,
				Parent           = container,
			})
			AddCorner(sectionFrame, 5)
			AddStroke(sectionFrame, Theme.SectionBorder, 1)
			AddPadding(sectionFrame, 8, 8, 8, 8)
			AddListLayout(sectionFrame, 3)

			local header = Make("Frame", {
				Name                   = "Header",
				Size                   = UDim2.new(1, 0, 0, 18),
				BackgroundTransparency = 1,
				ZIndex                 = 5,
				Parent                 = sectionFrame,
			})
			Make("TextLabel", {
				Size                   = UDim2.fromScale(1, 1),
				BackgroundTransparency = 1,
				Text                   = sname,
				TextColor3             = Theme.Accent,
				Font                   = Enum.Font.GothamBold,
				TextSize               = 10,
				TextXAlignment         = Enum.TextXAlignment.Left,
				ZIndex                 = 6,
				Parent                 = header,
			})
			Make("Frame", {
				Size             = UDim2.new(1, 0, 0, 1),
				Position         = UDim2.new(0, 0, 1, 0),
				BackgroundColor3 = Theme.AccentDark,
				ZIndex           = 6,
				Parent           = header,
			})

			local sectionObj = {}

			function sectionObj:AddToggle(label, default, callback)
				default  = default  or false
				callback = callback or function() end
				local state = default

				local row = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 22),
					BackgroundTransparency = 1,
					ZIndex                 = 6,
					Parent                 = sectionFrame,
				})
				Make("TextLabel", {
					Size                   = UDim2.new(1, -44, 1, 0),
					BackgroundTransparency = 1,
					Text                   = label,
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.Gotham,
					TextSize               = 11,
					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 7,
					Parent                 = row,
				})
				local track = Make("Frame", {
					Size             = UDim2.fromOffset(34, 16),
					Position         = UDim2.new(1, -34, 0.5, -8),
					BackgroundColor3 = state and Theme.Toggle_On or Theme.Toggle_Off,
					ZIndex           = 7,
					Parent           = row,
				})
				AddCorner(track, 99)
				AddStroke(track, Theme.SectionBorder, 1)
				local handle = Make("Frame", {
					Size             = UDim2.fromOffset(12, 12),
					Position         = state and UDim2.fromOffset(19, 2) or UDim2.fromOffset(2, 2),
					BackgroundColor3 = Color3.fromRGB(255, 255, 255),
					ZIndex           = 8,
					Parent           = track,
				})
				AddCorner(handle, 99)
				Make("TextButton", {
					Size                   = UDim2.fromScale(1, 1),
					BackgroundTransparency = 1,
					Text                   = "",
					ZIndex                 = 9,
					Parent                 = row,
				}).MouseButton1Click:Connect(function()
					state = not state
					Tween(track,  { BackgroundColor3 = state and Theme.Toggle_On or Theme.Toggle_Off }, 0.15)
					Tween(handle, { Position = state and UDim2.fromOffset(19, 2) or UDim2.fromOffset(2, 2) }, 0.15)
					callback(state)
				end)

				local obj = {}
				function obj:Set(v)
					state = v
					Tween(track,  { BackgroundColor3 = state and Theme.Toggle_On or Theme.Toggle_Off }, 0.15)
					Tween(handle, { Position = state and UDim2.fromOffset(19, 2) or UDim2.fromOffset(2, 2) }, 0.15)
					callback(state)
				end
				function obj:Get() return state end
				return obj
			end

			function sectionObj:AddButton(label, callback)
				callback = callback or function() end
				local btn = Make("TextButton", {
					Size             = UDim2.new(1, 0, 0, 24),
					BackgroundColor3 = Theme.Button_BG,
					Text             = "",
					ZIndex           = 6,
					ClipsDescendants = true,
					Parent           = sectionFrame,
				})
				AddCorner(btn, 4)
				AddStroke(btn, Theme.SectionBorder, 1)
				Make("TextLabel", {
					Size                   = UDim2.fromScale(1, 1),
					BackgroundTransparency = 1,
					Text                   = label,
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.GothamSemibold,
					TextSize               = 11,
					ZIndex                 = 7,
					Parent                 = btn,
				})
				btn.MouseEnter:Connect(function()
					Tween(btn, { BackgroundColor3 = Theme.Button_Hover }, 0.1)
				end)
				btn.MouseLeave:Connect(function()
					Tween(btn, { BackgroundColor3 = Theme.Button_BG }, 0.1)
				end)
				btn.MouseButton1Down:Connect(function()
					Tween(btn, { BackgroundColor3 = Theme.Button_Click }, 0.07)
				end)
				btn.MouseButton1Up:Connect(function()
					Tween(btn, { BackgroundColor3 = Theme.Button_Hover }, 0.1)
				end)
				btn.MouseButton1Click:Connect(function(x, y)
					RippleEffect(btn, x - btn.AbsolutePosition.X, y - btn.AbsolutePosition.Y)
					callback()
				end)

				local obj = {}
				function obj:SetLabel(t) btn:FindFirstChildOfClass("TextLabel").Text = t end
				return obj
			end

			function sectionObj:AddSlider(label, min, max, default, callback)
				min      = min      or 0
				max      = max      or 100
				default  = default  or min
				callback = callback or function() end
				local value = math.clamp(default, min, max)

				local wrapper = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 38),
					BackgroundTransparency = 1,
					ZIndex                 = 6,
					Parent                 = sectionFrame,
				})
				local labelRow = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 16),
					BackgroundTransparency = 1,
					ZIndex                 = 7,
					Parent                 = wrapper,
				})
				Make("TextLabel", {
					Size                   = UDim2.new(0.7, 0, 1, 0),
					BackgroundTransparency = 1,
					Text                   = label,
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.Gotham,
					TextSize               = 11,
					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 8,
					Parent                 = labelRow,
				})
				local valLabel = Make("TextLabel", {
					Size                   = UDim2.new(0.3, 0, 1, 0),
					Position               = UDim2.fromScale(0.7, 0),
					BackgroundTransparency = 1,
					Text                   = tostring(math.floor(value)),
					TextColor3             = Theme.Accent,
					Font                   = Enum.Font.GothamBold,
					TextSize               = 11,
					TextXAlignment         = Enum.TextXAlignment.Right,
					ZIndex                 = 8,
					Parent                 = labelRow,
				})
				local track = Make("Frame", {
					Size             = UDim2.new(1, 0, 0, 4),
					Position         = UDim2.fromOffset(0, 22),
					BackgroundColor3 = Theme.Slider_Track,
					ZIndex           = 7,
					Parent           = wrapper,
				})
				AddCorner(track, 99)
				local pct  = (value - min) / (max - min)
				local fill = Make("Frame", {
					Size             = UDim2.new(pct, 0, 1, 0),
					BackgroundColor3 = Theme.Slider_Fill,
					ZIndex           = 8,
					Parent           = track,
				})
				AddCorner(fill, 99)
				local handle = Make("Frame", {
					Size             = UDim2.fromOffset(12, 12),
					Position         = UDim2.new(pct, -6, 0.5, -6),
					BackgroundColor3 = Theme.Slider_Handle,
					ZIndex           = 9,
					Parent           = track,
				})
				AddCorner(handle, 99)
				AddStroke(handle, Theme.AccentDark, 2)
				Make("TextButton", {
					Size                   = UDim2.new(1, 0, 0, 20),
					Position               = UDim2.fromOffset(0, 18),
					BackgroundTransparency = 1,
					Text                   = "",
					ZIndex                 = 10,
					Parent                 = wrapper,
				})

				local function updateSlider(mouseX)
					local relX   = math.clamp(mouseX - track.AbsolutePosition.X, 0, track.AbsoluteSize.X)
					local newPct = relX / track.AbsoluteSize.X
					local newVal = math.floor(min + (max - min) * newPct)
					value            = newVal
					fill.Size        = UDim2.new(newPct, 0, 1, 0)
					handle.Position  = UDim2.new(newPct, -6, 0.5, -6)
					valLabel.Text    = tostring(newVal)
					callback(newVal)
				end

				local sliding = false
				wrapper:FindFirstChildOfClass("TextButton").MouseButton1Down:Connect(function()
					sliding = true
					updateSlider(UserInputService:GetMouseLocation().X)
				end)
				UserInputService.InputChanged:Connect(function(inp)
					if sliding and inp.UserInputType == Enum.UserInputType.MouseMovement then
						updateSlider(UserInputService:GetMouseLocation().X)
					end
				end)
				UserInputService.InputEnded:Connect(function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
				end)

				local obj = {}
				function obj:Set(v)
					value = math.clamp(v, min, max)
					local p = (value - min) / (max - min)
					fill.Size       = UDim2.new(p, 0, 1, 0)
					handle.Position = UDim2.new(p, -6, 0.5, -6)
					valLabel.Text   = tostring(math.floor(value))
					callback(value)
				end
				function obj:Get() return value end
				return obj
			end

			function sectionObj:AddDropdown(label, options, default, callback)
				callback = callback or function() end
				local selected = default or (options[1] or "")
				local opened   = false

				local wrapper = Make("Frame", {
					Size                   = UDim2.new(1, 0, 0, 22),
					BackgroundTransparency = 1,
					ZIndex                 = 6,
					ClipsDescendants       = false,
					Parent                 = sectionFrame,
				})
				Make("TextLabel", {
					Size                   = UDim2.new(0.45, 0, 1, 0),
					BackgroundTransparency = 1,
					Text                   = label,
					TextColor3             = Theme.Text,
					Font                   = Enum.Font.Gotham,
					TextSize               = 11,
					TextXAlignment         = Enum.TextXAlignment.Left,
					ZIndex                 = 7,
					Parent                 = wrapper,
				})
				local box = Make("TextButton", {
					Size             = UDim2.new(0.52, 0, 1, 0),
					Position         = UDim2.fromScale(0.47, 0),
