	end

	function WindowObj:Notify(cfg2)
		cfg2 = cfg2 or {}
		local nTitle = cfg2.Title or "Notification"
		local nText  = cfg2.Text  or ""
		local nTime  = cfg2.Time  or 3
		local nColor = cfg2.Color or Theme.Accent

		local notif = Make("Frame", {
			Size             = UDim2.fromOffset(220, 50),
			Position         = UDim2.new(1, 230, 1, -60),
			BackgroundColor3 = Theme.Section,
			ZIndex           = 100,
			Parent           = ScreenGui,
		})
		AddCorner(notif, 5)
		AddStroke(notif, nColor, 1)
		Make("Frame", {
			Size             = UDim2.fromOffset(3, 40),
			Position         = UDim2.fromOffset(0, 5),
			BackgroundColor3 = nColor,
			ZIndex           = 101,
			Parent           = notif,
		})
		Make("TextLabel", {
			Size                   = UDim2.new(1, -12, 0, 16),
			Position               = UDim2.fromOffset(10, 5),
			BackgroundTransparency = 1,
			Text                   = nTitle,
			TextColor3             = nColor,
			Font                   = Enum.Font.GothamBold,
			TextSize               = 11,
			TextXAlignment         = Enum.TextXAlignment.Left,
			ZIndex                 = 101,
			Parent                 = notif,
		})
		Make("TextLabel", {
			Size                   = UDim2.new(1, -12, 0, 22),
			Position               = UDim2.fromOffset(10, 22),
			BackgroundTransparency = 1,
			Text                   = nText,
			TextColor3             = Theme.SubText,
			Font                   = Enum.Font.Gotham,
			TextSize               = 10,
			TextXAlignment         = Enum.TextXAlignment.Left,
			TextWrapped            = true,
			ZIndex                 = 101,
			Parent                 = notif,
		})
		Tween(notif, { Position = UDim2.new(1, -230, 1, -60) }, 0.3, Enum.EasingStyle.Back)
		task.delay(nTime, function()
			Tween(notif, { Position = UDim2.new(1, 230, 1, -60), BackgroundTransparency = 1 }, 0.25)
			task.delay(0.26, function() notif:Destroy() end)
		end)
	end

	Window.Size = UDim2.fromOffset(size.X.Offset, 0)
	Tween(Window, { Size = size }, 0.3, Enum.EasingStyle.Back)

	return WindowObj
end

return Library
